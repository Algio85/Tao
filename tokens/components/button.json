{
  "button": {

    "_comment": "── Sizing tokens (no variant, no state) ──────────────────────────────────",

    "sm": {
      "spacing": {
        "horizontal": { "$value": "{spacing.sm}", "$type": "dimension", "$description": "Horizontal padding for sm button" },
        "vertical":   { "$value": "{spacing.xs}", "$type": "dimension", "$description": "Vertical padding for sm button" },
        "gap":        { "$value": "{spacing.xs}", "$type": "dimension", "$description": "Gap between icon and label for sm button" }
      },
      "font": {
        "size": { "$value": "{typography.size.sm}", "$type": "dimension", "$description": "Font size for sm button" }
      },
      "border": {
        "radius": { "$value": "{radius.sm}", "$type": "dimension", "$description": "Border radius for sm button" }
      }
    },

    "md": {
      "spacing": {
        "horizontal": { "$value": "{spacing.md}", "$type": "dimension", "$description": "Horizontal padding for md button" },
        "vertical":   { "$value": "{spacing.xs}", "$type": "dimension", "$description": "Vertical padding for md button" },
        "gap":        { "$value": "{spacing.xs}", "$type": "dimension", "$description": "Gap between icon and label for md button" }
      },
      "font": {
        "size": { "$value": "{typography.size.md}", "$type": "dimension", "$description": "Font size for md button" }
      },
      "border": {
        "radius": { "$value": "{radius.md}", "$type": "dimension", "$description": "Border radius for md button" }
      }
    },

    "lg": {
      "spacing": {
        "horizontal": { "$value": "{spacing.lg}", "$type": "dimension", "$description": "Horizontal padding for lg button" },
        "vertical":   { "$value": "{spacing.md}", "$type": "dimension", "$description": "Vertical padding for lg button" },
        "gap":        { "$value": "{spacing.sm}", "$type": "dimension", "$description": "Gap between icon and label for lg button" }
      },
      "font": {
        "size": { "$value": "{typography.size.lg}", "$type": "dimension", "$description": "Font size for lg button" }
      },
      "border": {
        "radius": { "$value": "{radius.md}", "$type": "dimension", "$description": "Border radius for lg button" }
      }
    },

    "_comment2": "── Primary variant ───────────────────────────────────────────────────────",

    "primary": {
      "background": {
        "color": { "$value": "{surface.brand-1.strong}", "$type": "color", "$description": "Background color of primary button default state" }
      },
      "text": {
        "color": { "$value": "{text.inverse}", "$type": "color", "$description": "Text color of primary button" }
      },
      "icon": {
        "color": { "$value": "{text.inverse}", "$type": "color", "$description": "Icon color of primary button" }
      },

      "hover": {
        "background": {
          "color": { "$value": "{surface.brand-1.strong}", "$type": "color", "$description": "Background color of primary button hover state" }
        }
      },

      "press": {
        "background": {
          "color": { "$value": "{surface.brand-1.strongest}", "$type": "color", "$description": "Background color of primary button press state" }
        }
      },

      "active": {
        "background": {
          "color": { "$value": "{surface.brand-1.strongest}", "$type": "color", "$description": "Background color of primary button active state" }
        },
        "hover": {
          "background": {
            "color": { "$value": "{surface.brand-1.strongest}", "$type": "color", "$description": "Background color of primary button active-hover state" }
          }
        },
        "press": {
          "background": {
            "color": { "$value": "{surface.brand-1.strongest}", "$type": "color", "$description": "Background color of primary button active-press state" }
          }
        }
      },

      "disabled": {
        "background": {
          "color": { "$value": "{state.disabled.bg}", "$type": "color", "$description": "Background color of primary button disabled state" }
        },
        "text": {
          "color": { "$value": "{state.disabled.text}", "$type": "color", "$description": "Text color of primary button disabled state" }
        },
        "icon": {
          "color": { "$value": "{state.disabled.text}", "$type": "color", "$description": "Icon color of primary button disabled state" }
        }
      },

      "loading": {
        "background": {
          "color": { "$value": "{surface.brand-1.strong}", "$type": "color", "$description": "Background color of primary button loading state" }
        }
      }
    },

    "_comment3": "── Ghost variant ─────────────────────────────────────────────────────────",

    "ghost": {
      "background": {
        "color": { "$value": "{surface.neutral.subtlest}", "$type": "color", "$description": "Background color of ghost button default state" }
      },
      "text": {
        "color": { "$value": "{text.default}", "$type": "color", "$description": "Text color of ghost button" }
      },
      "icon": {
        "color": { "$value": "{text.default}", "$type": "color", "$description": "Icon color of ghost button" }
      },

      "hover": {
        "background": {
          "color": { "$value": "{surface.neutral.subtle}", "$type": "color", "$description": "Background color of ghost button hover state" }
        }
      },

      "press": {
        "background": {
          "color": { "$value": "{surface.neutral.default}", "$type": "color", "$description": "Background color of ghost button press state" }
        }
      },

      "active": {
        "background": {
          "color": { "$value": "{surface.neutral.default}", "$type": "color", "$description": "Background color of ghost button active state" }
        },
        "hover": {
          "background": {
            "color": { "$value": "{surface.neutral.default}", "$type": "color", "$description": "Background color of ghost button active-hover state" }
          }
        },
        "press": {
          "background": {
            "color": { "$value": "{surface.neutral.strong}", "$type": "color", "$description": "Background color of ghost button active-press state" }
          },
          "text": {
            "color": { "$value": "{text.inverse}", "$type": "color", "$description": "Text color of ghost button active-press state (flipped for contrast)" }
          },
          "icon": {
            "color": { "$value": "{text.inverse}", "$type": "color", "$description": "Icon color of ghost button active-press state (flipped for contrast)" }
          }
        }
      },

      "disabled": {
        "background": {
          "color": { "$value": "{state.disabled.bg}", "$type": "color", "$description": "Background color of ghost button disabled state" }
        },
        "text": {
          "color": { "$value": "{state.disabled.text}", "$type": "color", "$description": "Text color of ghost button disabled state" }
        },
        "icon": {
          "color": { "$value": "{state.disabled.text}", "$type": "color", "$description": "Icon color of ghost button disabled state" }
        }
      },

      "loading": {
        "background": {
          "color": { "$value": "{surface.neutral.subtlest}", "$type": "color", "$description": "Background color of ghost button loading state" }
        }
      }
    },

    "_comment4": "── Danger variant ────────────────────────────────────────────────────────",

    "danger": {
      "background": {
        "color": { "$value": "{surface.danger.strong}", "$type": "color", "$description": "Background color of danger button default state" }
      },
      "text": {
        "color": { "$value": "{text.inverse}", "$type": "color", "$description": "Text color of danger button" }
      },
      "icon": {
        "color": { "$value": "{text.inverse}", "$type": "color", "$description": "Icon color of danger button" }
      },

      "hover": {
        "background": {
          "color": { "$value": "{surface.danger.strong}", "$type": "color", "$description": "Background color of danger button hover state" }
        }
      },

      "press": {
        "background": {
          "color": { "$value": "{surface.danger.strongest}", "$type": "color", "$description": "Background color of danger button press state" }
        }
      },

      "active": {
        "background": {
          "color": { "$value": "{surface.danger.strongest}", "$type": "color", "$description": "Background color of danger button active state" }
        },
        "hover": {
          "background": {
            "color": { "$value": "{surface.danger.strongest}", "$type": "color", "$description": "Background color of danger button active-hover state" }
          }
        },
        "press": {
          "background": {
            "color": { "$value": "{surface.danger.strongest}", "$type": "color", "$description": "Background color of danger button active-press state" }
          }
        }
      },

      "disabled": {
        "background": {
          "color": { "$value": "{state.disabled.bg}", "$type": "color", "$description": "Background color of danger button disabled state" }
        },
        "text": {
          "color": { "$value": "{state.disabled.text}", "$type": "color", "$description": "Text color of danger button disabled state" }
        },
        "icon": {
          "color": { "$value": "{state.disabled.text}", "$type": "color", "$description": "Icon color of danger button disabled state" }
        }
      },

      "loading": {
        "background": {
          "color": { "$value": "{surface.danger.strong}", "$type": "color", "$description": "Background color of danger button loading state" }
        }
      }
    }

  }
}