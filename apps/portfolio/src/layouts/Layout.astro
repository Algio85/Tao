---
import '../../../../packages/tao/build/css/tokens.css';
import '../../tao-overrides.css';

const { title, description = 'Portfolio — Design that connects.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/stark.lab.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- DM Sans: UI, body, nav -->
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
<title>{title}</title>
  </head>
  <body>
    <slot />
    <footer role="contentinfo" class="sr-only" aria-label="Site footer"></footer>
  </body>
</html>

<style is:global>
  :root {
    --nav-height: 64px;
    --container-max: 1200px;
  }

  *, *::before, *::after { box-sizing: border-box; }

  html {
    -webkit-text-size-adjust: 100%;
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: color-mix(in srgb, var(--tao-surface-brand-2-subtlest) 64%, var(--tao-surface-neutral-white));
    color: var(--tao-text-default);
    font-size: var(--tao-typography-size-md);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Focus ring — only for keyboard nav */
  :focus { outline: none; }
  :focus-visible {
    outline: var(--tao-border-width-md) solid var(--tao-border-brand-2);
    outline-offset: 3px;
    border-radius: var(--tao-radius-sm);
  }

  /* Skip link for screen readers */
  .skip-link {
    position: absolute;
    top: -100%;
    left: var(--tao-spacing-md);
    background: var(--tao-surface-brand-2-strong);
    color: var(--tao-text-inverse);
    font-size: var(--tao-typography-size-sm);
    font-weight: 600;
    padding: var(--tao-spacing-sm) var(--tao-spacing-lg);
    border-radius: 0 0 var(--tao-radius-md) var(--tao-radius-md);
    text-decoration: none;
    z-index: 9999;
    transition: top 0.15s;
  }
  .skip-link:focus { top: 0; }

  @media (prefers-reduced-motion: reduce) {
    .skip-link { transition: none; }
    html { scroll-behavior: auto; }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }
</style>
