---
import { HeroButtons } from './HeroButtons.jsx';
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="hero__container">

    <!-- ── Left: text content ───────────────────────────────────────── -->
    <div class="hero__content">

      <span class="hero__badge" aria-label="Tagline: Strategy, Execution, Vision">
        STRATEGY • EXECUTION • VISION
      </span>

      <h1 class="hero__heading" id="hero-heading">
        Design That<br />
        <em class="hero__accent">Connects.</em>
      </h1>

      <p class="hero__body">
        Hello, I'm <strong>Alessandro</strong> 👋🏻<br /><br />
        I am a Design Operations expert and pragmatic leader who thrives at the intersection of strategic vision and high-fidelity execution. My approach is rooted in systems thinking and a deep commitment to accessibility. I believe that well-crafted frameworks are the "seeds" that streamline complex processes, empowering teams to scale and innovate without friction.
      </p>

      <div class="hero__actions">
        <HeroButtons />
      </div>
    </div>

    <!-- ── Right: animated visual (decorative) ─────────────────────── -->
    <div class="hero__visual" aria-hidden="true" role="presentation">
      <div class="hero__diagram">

        <!-- SVG layer: background ring + triangle lines -->
        <svg
          class="diagram-svg"
          viewBox="0 0 480 430"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <!-- Triangle edges — animated dashes -->
          <line class="tri-line tri-line--a" x1="240" y1="52" x2="66" y2="346"
            stroke="var(--tao-border-brand-2)" stroke-width="1.5"
            stroke-dasharray="7 5" stroke-linecap="round" opacity="0.4" />
          <line class="tri-line tri-line--b" x1="66" y1="346" x2="414" y2="346"
            stroke="var(--tao-border-brand-2)" stroke-width="1.5"
            stroke-dasharray="7 5" stroke-linecap="round" opacity="0.4" />
          <line class="tri-line tri-line--c" x1="414" y1="346" x2="240" y2="52"
            stroke="var(--tao-border-brand-2)" stroke-width="1.5"
            stroke-dasharray="7 5" stroke-linecap="round" opacity="0.4" />
          <!-- Spoke lines — origin at visual midpoint: x=240, y=(52+346)/2=199 -->
          <line x1="240" y1="199" x2="240" y2="72"  stroke="var(--tao-border-brand-2)" stroke-width="1" stroke-dasharray="3 6" opacity="0.15" />
          <line x1="240" y1="199" x2="86"  y2="336" stroke="var(--tao-border-brand-2)" stroke-width="1" stroke-dasharray="3 6" opacity="0.15" />
          <line x1="240" y1="199" x2="394" y2="336" stroke="var(--tao-border-brand-2)" stroke-width="1" stroke-dasharray="3 6" opacity="0.15" />
        </svg>

        <!-- ── Vertex node cards ── -->
        <!-- TECHNOLOGY — top -->
        <div class="node node--technology">
          <!-- Phosphor: Cpu -->
          <svg class="node__icon" width="12" height="12" viewBox="0 0 256 256" fill="none" aria-hidden="true">
            <rect x="88" y="88" width="80" height="80" rx="8" stroke="currentColor" stroke-width="20"/>
            <line x1="128" y1="16" x2="128" y2="56" stroke="currentColor" stroke-width="18" stroke-linecap="round"/>
            <line x1="160" y1="16" x2="160" y2="56" stroke="currentColor" stroke-width="18" stroke-linecap="round"/>
            <line x1="96"  y1="16" x2="96"  y2="56" stroke="currentColor" stroke-width="18" stroke-linecap="round"/>
            <line x1="128" y1="200" x2="128" y2="240" stroke="currentColor" stroke-width="18" stroke-linecap="round"/>
            <line x1="160" y1="200" x2="160" y2="240" stroke="currentColor" stroke-width="18" stroke-linecap="round"/>
            <line x1="96"  y1="200" x2="96"  y2="240" stroke="currentColor" stroke-width="18" stroke-linecap="round"/>
            <line x1="200" y1="128" x2="240" y2="128" stroke="currentColor" stroke-width="18" stroke-linecap="round"/>
            <line x1="200" y1="160" x2="240" y2="160" stroke="currentColor" stroke-width="18" stroke-linecap="round"/>
            <line x1="200" y1="96"  x2="240" y2="96"  stroke="currentColor" stroke-width="18" stroke-linecap="round"/>
            <line x1="16"  y1="128" x2="56"  y2="128" stroke="currentColor" stroke-width="18" stroke-linecap="round"/>
            <line x1="16"  y1="160" x2="56"  y2="160" stroke="currentColor" stroke-width="18" stroke-linecap="round"/>
            <line x1="16"  y1="96"  x2="56"  y2="96"  stroke="currentColor" stroke-width="18" stroke-linecap="round"/>
          </svg>
          TECHNOLOGY
        </div>

        <!-- DESIGN — bottom-left -->
        <div class="node node--design">
          <!-- Phosphor: Pen nib / SquaresFour simplified -->
          <svg class="node__icon" width="12" height="12" viewBox="0 0 256 256" fill="none" aria-hidden="true">
            <rect x="32"  y="32"  width="80" height="80" rx="8" stroke="currentColor" stroke-width="20"/>
            <rect x="144" y="32"  width="80" height="80" rx="8" stroke="currentColor" stroke-width="20"/>
            <rect x="32"  y="144" width="80" height="80" rx="8" stroke="currentColor" stroke-width="20"/>
            <rect x="144" y="144" width="80" height="80" rx="8" stroke="currentColor" stroke-width="20"/>
          </svg>
          DESIGN
        </div>

        <!-- BUSINESS — bottom-right -->
        <div class="node node--business">
          <!-- Phosphor: Globe -->
          <svg class="node__icon" width="12" height="12" viewBox="0 0 256 256" fill="none" aria-hidden="true">
            <circle cx="128" cy="128" r="104" stroke="currentColor" stroke-width="18"/>
            <ellipse cx="128" cy="128" rx="44" ry="104" stroke="currentColor" stroke-width="18"/>
            <line x1="24" y1="128" x2="232" y2="128" stroke="currentColor" stroke-width="18" stroke-linecap="round"/>
          </svg>
          BUSINESS
        </div>

        <!-- ── Center card with network icon ── -->
        <div class="center-card">
          <div class="center-card__ring"></div>
          <div class="center-card__ring center-card__ring--2"></div>
          <div class="center-card__body">
            <!-- Phosphor: Lightning -->
            <svg width="24" height="24" viewBox="0 0 256 256" fill="none" aria-hidden="true">
              <path d="M213.85,125.46l-112,120a8,8,0,0,1-13.69-7l14.66-73.33L48.15,130.54a8,8,0,0,1,1.69-13l112-56a8,8,0,0,1,10.67,10.54L148,152h56a8,8,0,0,1,9.87,9.87Z"
                fill="var(--tao-text-brand-2)"/>
            </svg>
          </div>
        </div>


      </div>
    </div>

  </div>
</section>

<style>
  /* ═══════════════════════════════════════════════════════
     HERO SECTION
  ═══════════════════════════════════════════════════════ */

  .hero {
    background: color-mix(in srgb, var(--tao-surface-brand-2-subtlest) 64%, var(--tao-surface-neutral-white));
    min-height: calc(100svh - var(--nav-height));
    display: flex;
    align-items: center;
    padding: var(--tao-spacing-xxl) 0;
    overflow: hidden;
  }

  .hero__container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--tao-spacing-xl);
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: var(--tao-spacing-xxl);
    align-items: center;
  }

  /* ─── Left column ─────────────────────────────────────── */

  .hero__content {
    display: flex;
    flex-direction: column;
    gap: var(--tao-spacing-md);
    animation: fade-slide-up 0.7s ease both;
  }

  .hero__badge {
    display: inline-flex;
    align-self: flex-start;
    font-size: var(--tao-typography-size-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--tao-text-ai);
    background: var(--tao-surface-ai-subtlest);
    border: var(--tao-border-width-sm) solid color-mix(in srgb, var(--tao-border-ai) calc(var(--tao-opacity-64) * 100%), transparent);
    border-radius: var(--tao-radius-pill);
    padding: var(--tao-spacing-xs) var(--tao-spacing-md);
  }

  .hero__heading {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(
      calc(var(--tao-typography-size-xxxl) * 1.1),
      4vw,
      calc(var(--tao-typography-size-xxxl) * 1.55)
    );
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.04em;
    color: var(--tao-text-default);
    margin: 0;
  }

  .hero__accent {
    font-family: 'DM Sans', sans-serif;
    font-style: italic;
    font-weight: 800;
    color: var(--tao-text-brand-2);
    display: inline-block;
    letter-spacing: -0.04em;
  }

  .hero__body {
    font-size: var(--tao-typography-size-md);
    font-weight: 400;
    line-height: 1.65;
    color: var(--tao-text-subtle);
    margin: 0;
    max-width: 44ch;
  }

  .hero__body strong {
    color: var(--tao-text-default);
    font-weight: 600;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--tao-spacing-md);
    margin-top: var(--tao-spacing-xs);
  }

  .hero__btn {
    display: inline-flex;
    align-items: center;
    gap: var(--tao-spacing-xs);
    font-size: var(--tao-typography-size-md);
    font-weight: 600;
    text-decoration: none;
    border-radius: var(--tao-radius-md);
    padding: var(--tao-spacing-sm) var(--tao-spacing-lg);
    transition: transform 0.15s, background 0.15s, color 0.15s;
    border: var(--tao-border-width-md) solid transparent;
  }

  .hero__btn:focus-visible {
    outline: var(--tao-border-width-md) solid var(--tao-border-brand-2);
    outline-offset: 4px;
  }

  .hero__btn:active { transform: translateY(1px); }

  .hero__btn--primary {
    background: var(--tao-surface-brand-2-strong);
    color: var(--tao-text-inverse);
    border-color: var(--tao-surface-brand-2-strong);
  }
  .hero__btn--primary:hover {
    background: var(--tao-surface-brand-2-strongest);
    border-color: var(--tao-surface-brand-2-strongest);
    transform: translateY(-2px);
  }

  .hero__btn--secondary {
    background: transparent;
    color: var(--tao-text-default);
    border-color: var(--tao-border-default);
  }
  .hero__btn--secondary:hover {
    background: var(--tao-state-hover);
    transform: translateY(-2px);
  }

  /* ─── Right column: diagram wrapper ─────────────────────── */

  .hero__visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero__diagram {
    position: relative;
    width: 570px;
    height: 510px;
    flex-shrink: 0;
    animation: float 5s ease-in-out infinite, fade-slide-up 0.9s 0.2s ease both;
  }

  /* ─── SVG layer ─────────────────────────────────────────── */

  .diagram-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    color: var(--tao-text-brand-2);
  }

  /* Marching-ants on triangle lines */
  .tri-line { stroke-dashoffset: 0; }
  .tri-line--a { animation: dash-flow 4s linear infinite; }
  .tri-line--b { animation: dash-flow 4s 1.33s linear infinite; }
  .tri-line--c { animation: dash-flow 4s 2.66s linear infinite; }


  /* ─── Label nodes ────────────────────────────────────────── */

  .node {
    position: absolute;
    display: flex;
    align-items: center;
    gap: var(--tao-spacing-xxs);
    font-size: var(--tao-typography-size-sm);
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--tao-text-default);
    background: var(--tao-surface-neutral-white);
    border: var(--tao-border-width-sm) solid var(--tao-border-default);
    border-radius: var(--tao-radius-sm);
    padding: var(--tao-spacing-xxs) var(--tao-spacing-sm);
    box-shadow: 0 2px 8px color-mix(in srgb, var(--tao-border-default) calc(var(--tao-opacity-32) * 100%), transparent);
    white-space: nowrap;
    animation: node-fade-in 0.5s ease both;
  }

  .node__icon {
    color: var(--tao-text-brand-2);
    flex-shrink: 0;
  }

  /* TECHNOLOGY: top vertex (240,52) → 50%, 12.1% */
  .node--technology {
    left: 50%;
    top: 12.1%;
    transform: translate(-50%, -50%);
    animation-delay: 0.4s;
  }

  /* DESIGN: bottom-left vertex (66,346) → 13.75%, 80.5% */
  .node--design {
    left: 13.75%;
    top: 80.5%;
    transform: translate(-50%, -50%);
    animation-delay: 0.6s;
  }

  /* BUSINESS: bottom-right vertex (414,346) → 86.25%, 80.5% */
  .node--business {
    left: 86.25%;
    top: 80.5%;
    transform: translate(-50%, -50%);
    animation-delay: 0.5s;
  }

  /* ─── Center card ─────────────────────────────────────────── */

  .center-card {
    position: absolute;
    left: 50%;
    top: 55.3%;
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    justify-content: center;
    /* NO animation here — animation would overwrite the translate transform */
  }

  .center-card__ring {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 66px;
    height: 66px;
    border-radius: var(--tao-radius-circular);
    border: var(--tao-border-width-sm) solid var(--tao-border-brand-2);
    opacity: 0;
    animation: hero-pulse-ring 3s 1s ease-out infinite;
  }
  .center-card__ring--2 {
    animation: hero-pulse-ring 3s 2s ease-out infinite;
  }

  .center-card__body {
    position: relative;
    z-index: 1;
    width: 58px;
    height: 58px;
    background: var(--tao-surface-neutral-white);
    border-radius: var(--tao-radius-lg);
    border: var(--tao-border-width-sm) solid var(--tao-border-default);
    box-shadow: 0 4px 16px color-mix(in srgb, var(--tao-border-default) calc(var(--tao-opacity-48) * 100%), transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    animation: fade-in 0.5s 0.3s ease both;
  }


  /* ═══════════════════════════════════════════════════════
     KEYFRAMES
  ═══════════════════════════════════════════════════════ */

  @keyframes float {
    0%, 100% { transform: translateY(0px);   }
    50%       { transform: translateY(-10px); }
  }

  @keyframes fade-slide-up {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0);    }
  }

  @keyframes fade-in {
    from { opacity: 0; transform: scale(0.93); }
    to   { opacity: 1; transform: scale(1);    }
  }

  /* Nodes use translate(-50%,-50%) for positioning — keep it in the keyframe */
  @keyframes node-fade-in {
    from { opacity: 0; transform: translate(-50%, -50%) scale(0.93); }
    to   { opacity: 1; transform: translate(-50%, -50%) scale(1);    }
  }

  @keyframes dash-flow {
    to { stroke-dashoffset: -48; }
  }

  @keyframes hero-pulse-ring {
    0%   { transform: translate(-50%, -50%) scale(1);   opacity: 0.7; }
    100% { transform: translate(-50%, -50%) scale(1.9); opacity: 0;   }
  }

  /* ═══════════════════════════════════════════════════════
     RESPONSIVE
  ═══════════════════════════════════════════════════════ */

  @media (max-width: 960px) {
    .hero__container {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero__badge  { align-self: center; }
    .hero__body   { max-width: none; }
    .hero__actions { justify-content: center; }

    .hero__visual {
      order: -1;
    }
    .hero__diagram {
      width: 300px;
      height: 270px;
    }
  }

  @media (max-width: 520px) {
    .hero {
      padding: var(--tao-spacing-xl) 0;
    }
    .hero__container {
      padding: 0 var(--tao-spacing-lg);
    }
    .hero__diagram {
      width: 260px;
      height: 230px;
    }
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .tri-line,
    .hero__diagram,
    .center-card__ring {
      animation: none;
    }
    .hero__content,
    .node,
    .center-card {
      animation: none;
      opacity: 1;
    }
  }
</style>
