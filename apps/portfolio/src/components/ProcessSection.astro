---
---

<section class="process" id="methodology" aria-labelledby="process-heading">
  <div class="process__container">

    <div class="process__header">
      <h2 class="process__label" id="process-heading">My Process</h2>
      <p class="process__subtitle">5-step methodology</p>
    </div>

    <div class="process__row">
      <div class="process__line-track" aria-hidden="true">
        <div class="process__line-fill"></div>
      </div>

      <div class="process__step">
        <div class="step__dot" aria-hidden="true"><div class="step__dot-inner"></div></div>
        <div class="step__content">
          <div class="step__number">01</div>
          <div class="step__title">Identifying key users jobs to be done</div>
          <div class="step__desc">e.g. filtering information when searching for insights.</div>
        </div>
      </div>

      <div class="process__step">
        <div class="step__dot" aria-hidden="true"><div class="step__dot-inner"></div></div>
        <div class="step__content">
          <div class="step__number">02</div>
          <div class="step__title">Focusing on prioritizing their problems and needs</div>
          <div class="step__desc">e.g. reducing noise while preserving what matters.</div>
        </div>
      </div>

      <div class="process__step">
        <div class="step__dot" aria-hidden="true"><div class="step__dot-inner"></div></div>
        <div class="step__content">
          <div class="step__number">03</div>
          <div class="step__title">Identifying company business outcomes</div>
          <div class="step__desc">e.g. drive a 25% increase in course imports by streamlining discovery and reducing UI noise.</div>
        </div>
      </div>

      <div class="process__step">
        <div class="step__dot" aria-hidden="true"><div class="step__dot-inner"></div></div>
        <div class="step__content">
          <div class="step__number">04</div>
          <div class="step__title">Solutions that address this need</div>
          <div class="step__desc">e.g. granular filtering system, AI-driven prioritization, personalized relevance models.</div>
        </div>
      </div>

      <div class="process__step">
        <div class="step__dot" aria-hidden="true"><div class="step__dot-inner"></div></div>
        <div class="step__content">
          <div class="step__number">05</div>
          <div class="step__title">Evaluation of the solution</div>
          <div class="step__desc">e.g. experimentation with real users and defined metrics.</div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  /* ═══════════════════════════════════════════════════════
     PROCESS SECTION
  ═══════════════════════════════════════════════════════ */

  .process {
    --process-dot-size: 44px;
    background: var(--tao-surface-neutral-white);
    padding: var(--tao-spacing-xxl) 0;
  }

  .process__container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--tao-spacing-xl);
  }

  /* ─── Header ────────────────────────────────────────── */

  .process__header {
    margin-bottom: var(--tao-spacing-xl);
  }

  .process__label {
    color: var(--tao-text-default);
    font-size: var(--tao-typography-size-xl);
    font-weight: 700;
    margin: 0 0 var(--tao-spacing-xs);
    line-height: 1.15;
    opacity: 0;
    transform: translateY(var(--tao-spacing-sm));
    transition:
      opacity   500ms cubic-bezier(0, 0, 0.2, 1),
      transform 500ms cubic-bezier(0, 0, 0.2, 1);
  }

  .process.in-view .process__label {
    opacity: 1;
    transform: translateY(0);
  }

  .process__subtitle {
    font-size: var(--tao-typography-size-md);
    color: var(--tao-text-subtle);
    margin: 0;
  }

  /* ─── Row ────────────────────────────────────────────── */

  .process__row {
    display: flex;
    gap: 0;
    position: relative;
  }

  /* ─── Connecting line ────────────────────────────────── */

  .process__line-track {
    position: absolute;
    top: calc(var(--process-dot-size) / 2);
    left: calc(var(--process-dot-size) / 2);
    width: calc(100% - var(--process-dot-size));
    height: var(--tao-border-width-md);
    background: var(--tao-surface-brand-2-subtlest);
    z-index: 0;
    overflow: hidden;
  }

  .process__line-fill {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      var(--tao-surface-brand-2-strongest) 0%,
      var(--tao-surface-brand-2-subtle)    100%
    );
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 1000ms cubic-bezier(0.4, 0, 0.2, 1) 300ms;
  }

  .process.in-view .process__line-fill {
    transform: scaleX(1);
  }

  /* ─── Steps ──────────────────────────────────────────── */

  .process__step {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 0 var(--tao-spacing-md) 0 0;
    position: relative;
    z-index: 1;
    opacity: 0;
    transform: translateY(var(--tao-spacing-lg));
    transition:
      opacity   500ms cubic-bezier(0, 0, 0.2, 1),
      transform 500ms cubic-bezier(0, 0, 0.2, 1);
  }

  .process__step:last-child { padding-right: 0; }

  .process__step:nth-child(1) { transition-delay: 0.20s; }
  .process__step:nth-child(2) { transition-delay: 0.38s; }
  .process__step:nth-child(3) { transition-delay: 0.56s; }
  .process__step:nth-child(4) { transition-delay: 0.74s; }
  .process__step:nth-child(5) { transition-delay: 0.92s; }

  .process.in-view .process__step {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── Dot ────────────────────────────────────────────── */

  .step__dot {
    width: var(--process-dot-size);
    height: var(--process-dot-size);
    border-radius: var(--tao-radius-circular);
    background: var(--tao-surface-brand-2-subtle);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--tao-spacing-md);
    flex-shrink: 0;
    transition:
      transform  300ms cubic-bezier(0.34, 1.56, 0.64, 1),
      background 200ms cubic-bezier(0, 0, 0.2, 1);
    cursor: default;
  }

  .step__dot:hover {
    transform: scale(1.15);
    background: var(--tao-surface-brand-2-default);
  }

  .step__dot-inner {
    width: calc(var(--process-dot-size) / 2);
    height: calc(var(--process-dot-size) / 2);
    border-radius: var(--tao-radius-circular);
    background: var(--tao-surface-brand-2-strong);
    transition: transform 300ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .step__dot:hover .step__dot-inner {
    transform: scale(0.82);
  }

  @keyframes pulse-ring {
    0%, 100% { box-shadow: 0 0 0 0px color-mix(in srgb, var(--tao-border-brand-2) 28%, transparent); }
    50%       { box-shadow: 0 0 0 8px  color-mix(in srgb, var(--tao-border-brand-2)  0%, transparent); }
  }

  .process.in-view .process__step:nth-child(1) .step__dot { animation: pulse-ring 3s cubic-bezier(0.4,0,0.2,1) 1.2s infinite; }
  .process.in-view .process__step:nth-child(2) .step__dot { animation: pulse-ring 3s cubic-bezier(0.4,0,0.2,1) 1.6s infinite; }
  .process.in-view .process__step:nth-child(3) .step__dot { animation: pulse-ring 3s cubic-bezier(0.4,0,0.2,1) 2.0s infinite; }
  .process.in-view .process__step:nth-child(4) .step__dot { animation: pulse-ring 3s cubic-bezier(0.4,0,0.2,1) 2.4s infinite; }
  .process.in-view .process__step:nth-child(5) .step__dot { animation: pulse-ring 3s cubic-bezier(0.4,0,0.2,1) 2.8s infinite; }

  /* ─── Text ────────────────────────────────────────────── */

  .step__number {
    font-size: var(--tao-typography-size-xs);
    font-weight: 700;
    color: var(--tao-text-subtlest);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--tao-spacing-xxs);
  }

  .step__title {
    font-size: var(--tao-typography-size-lg);
    font-weight: 700;
    color: var(--tao-text-default);
    line-height: 1.3;
    margin-bottom: var(--tao-spacing-xs);
  }

  .step__desc {
    font-size: var(--tao-typography-size-sm);
    color: var(--tao-text-subtle);
    line-height: 1.5;
  }

  /* ─── Reduced motion ─────────────────────────────────── */

  @media (prefers-reduced-motion: reduce) {
    .process__label,
    .process__step {
      transition: none;
      opacity: 1;
      transform: none;
    }
    .process__line-fill {
      transition: none;
      transform: scaleX(1);
    }
    .step__dot { animation: none !important; }
  }

  /* ─── Responsive ─────────────────────────────────────── */

  @media (max-width: 768px) {
    .process__row {
      flex-direction: column;
      gap: var(--tao-spacing-xl);
    }

    .process__line-track {
      top: calc(var(--process-dot-size) / 2);
      left: calc(var(--process-dot-size) / 2 - 1px);
      width: var(--tao-border-width-md);
      height: calc(100% - var(--process-dot-size) / 2);
    }

    .process__line-fill {
      background: linear-gradient(
        180deg,
        var(--tao-surface-brand-2-strongest) 0%,
        var(--tao-surface-brand-2-subtle)    100%
      );
      transform: scaleY(0);
      transform-origin: top;
      transition: transform 1000ms cubic-bezier(0.4, 0, 0.2, 1) 300ms;
    }

    .process.in-view .process__line-fill {
      transform: scaleY(1);
    }

    .process__step {
      flex-direction: row;
      align-items: flex-start;
      gap: var(--tao-spacing-lg);
      padding: 0;
    }

    .step__dot     { margin-bottom: 0; }
    .step__content { padding-top: var(--tao-spacing-xs); }
  }
</style>

<script>
  (function () {
    const section = document.getElementById('methodology');
    if (!section) return;
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            section.classList.add('in-view');
            observer.disconnect();
          }
        });
      },
      { threshold: 0.15 }
    );
    observer.observe(section);
  })();
</script>
