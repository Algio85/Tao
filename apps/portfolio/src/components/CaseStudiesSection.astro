  .work-card__logo {
    position: absolute;
    top: var(--tao-spacing-xl);
    right: var(--tao-spacing-xl);
    height: 18px;
    width: auto;
    object-fit: contain;
  }

  /* ─── Card text ──────────────────────────────────────── */

  .work-card__body { flex: 1; }

  .work-card__title {
    font-size: var(--tao-typography-size-lg);
    font-weight: 700;
    color: var(--tao-text-default);
    margin: 0 0 var(--tao-spacing-xs);
    line-height: 1.3;
  }

  .work-card__desc {
    font-size: var(--tao-typography-size-md);
    color: var(--tao-text-subtle);
    margin: 0;
    line-height: 1.6;
  }

  /* ─── Learn more link ───────────────────────────────── */

  .work-card__link {
    display: inline-flex;
    align-items: center;
    gap: var(--tao-spacing-xxs);
    font-size: var(--tao-typography-size-md);
    font-weight: 600;
    color: var(--tao-text-brand-2);
    text-decoration: none;
    transition: gap 0.15s;
  }
  .work-card__link:hover { gap: var(--tao-spacing-xs); }

  /* ─── Tag chips ──────────────────────────────────────── */

  .work-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--tao-spacing-xs);
  }

  .work-card__tag {
    font-size: var(--tao-typography-size-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--tao-text-default);
    border: var(--tao-border-width-sm) solid var(--tao-border-default);
    border-radius: var(--tao-radius-pill);
    padding: var(--tao-spacing-xxs) var(--tao-spacing-sm);
  }

  /* ─── Image card ─────────────────────────────────────── */

  .work-card--image {
    padding: 0;
    min-height: 280px;
    border: var(--tao-border-width-sm) solid var(--tao-border-subtle);
  }

  .work-card__image-art {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      145deg,
      var(--tao-surface-brand-2-subtlest) 0%,
      var(--tao-surface-brand-1-subtle)   55%,
      var(--tao-surface-brand-3-subtlest) 100%
    );
  }

  .image-art__grid {
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(0deg, color-mix(in srgb, var(--tao-border-brand-1) 18%, transparent) 0px, transparent 1px, transparent 36px),
      repeating-linear-gradient(90deg, color-mix(in srgb, var(--tao-border-brand-1) 18%, transparent) 0px, transparent 1px, transparent 36px);
  }

  .image-art__glow {
    position: absolute;
    border-radius: var(--tao-radius-circular);
    filter: blur(28px);
  }
  .image-art__glow--a { width: 160px; height: 160px; background: var(--tao-surface-brand-2-subtle); top: 10%; left: 15%; opacity: 0.6; }
  .image-art__glow--b { width: 120px; height: 120px; background: var(--tao-surface-brand-3-subtle); bottom: 15%; right: 20%; opacity: 0.5; }

  /* ─── Bottom row cards ───────────────────────────────── */

  .work-card--bottom-1,
  .work-card--bottom-2 {
    opacity: 0;
    transform: translateY(calc(var(--tao-spacing-md) + var(--tao-spacing-xs)));
    transition:
      opacity  600ms cubic-bezier(0, 0, 0.2, 1),
      transform 600ms cubic-bezier(0, 0, 0.2, 1);
  }

  .works.in-view .work-card--bottom-1 { opacity: 1; transform: translateY(0); transition-delay: 130ms; }
  .works.in-view .work-card--bottom-2 { opacity: 1; transform: translateY(0); transition-delay: 230ms; }

  /* ─── Dark card ──────────────────────────────────────── */

  .work-card--dark {
    background: var(--tao-surface-brand-1-strongest);
    flex-direction: row;
    align-items: center;
    gap: var(--tao-spacing-xl);
    min-height: 300px;
  }

  .work-card--wide { grid-column: span 2; }

  .work-card__dark-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--tao-spacing-lg);
    min-width: 0;
  }

  .work-card--dark .work-card__title { color: var(--tao-text-inverse); font-size: var(--tao-typography-size-xxl); }
  .work-card--dark .work-card__desc  { color: color-mix(in srgb, var(--tao-text-inverse) 80%, transparent); }

  /* ─── Pill button ────────────────────────────────────── */

  .work-card__pill-btn {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    font-size: var(--tao-typography-size-sm);
    font-weight: 600;
    color: var(--tao-text-inverse);
    background: transparent;
    border: var(--tao-border-width-sm) solid color-mix(in srgb, var(--tao-text-inverse) 35%, transparent);
    border-radius: var(--tao-radius-pill);
    padding: var(--tao-spacing-xs) var(--tao-spacing-lg);
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }
  .work-card__pill-btn:hover {
    background: color-mix(in srgb, var(--tao-text-inverse) 10%, transparent);
    border-color: color-mix(in srgb, var(--tao-text-inverse) 55%, transparent);
  }
  .work-card__pill-btn:focus-visible { outline: var(--tao-border-width-md) solid var(--tao-state-focus); outline-offset: 3px; }

  /* ─── Decorative orb ─────────────────────────────────── */

  .work-card__dark-visual {
    width: 210px; height: 210px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .work-card__orb {
    width: 190px; height: 190px;
    border-radius: 55% 45% 60% 40% / 50% 60% 40% 55%;
    background: radial-gradient(
      ellipse at 38% 32%,
      var(--tao-surface-brand-3-subtle),
      var(--tao-surface-brand-2-subtle) 45%,
      var(--tao-surface-brand-1-subtle) 78%,
      transparent 100%
    );
    filter: blur(3px);
    animation: orb-breathe 7s ease-in-out infinite;
  }

  @keyframes orb-breathe {
    0%, 100% { border-radius: 55% 45% 60% 40% / 50% 60% 40% 55%; transform: scale(1) rotate(0deg); }
    33%       { border-radius: 42% 58% 38% 62% / 58% 42% 62% 38%; transform: scale(1.04) rotate(6deg); }
    66%       { border-radius: 60% 40% 55% 45% / 44% 56% 48% 52%; transform: scale(0.97) rotate(-4deg); }
  }

  /* ─── Brand card ─────────────────────────────────────── */

  .work-card--brand {
    background: var(--tao-surface-brand-2-bold);
    justify-content: space-between;
    min-height: 300px;
  }

  .work-card__brand-icon { color: var(--tao-text-inverse); }
  .work-card--brand .work-card__title { color: var(--tao-text-inverse); font-size: var(--tao-typography-size-xxl); }
  .work-card--brand .work-card__desc  { color: color-mix(in srgb, var(--tao-text-inverse) 85%, transparent); }

  /* ─── Circle arrow button ────────────────────────────── */

  .work-card__circle-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px; height: 48px;
    border-radius: var(--tao-radius-circular);
    background: var(--tao-text-inverse);
    border: none;
    cursor: pointer;
    color: var(--tao-surface-brand-2-bold);
    transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    align-self: flex-start;
    margin-top: var(--tao-spacing-xs);
  }
  .work-card__circle-btn:hover { transform: scale(1.1) translateX(4px); }
  .work-card__circle-btn:focus-visible {
    outline: var(--tao-border-width-md) solid color-mix(in srgb, var(--tao-text-inverse) 60%, transparent);
    outline-offset: 3px;
  }

  .work-card__cta {
    align-self: flex-start;
    margin-top: var(--tao-spacing-xs);
    --tao-button-bg:                  var(--tao-surface-neutral-white);
    --tao-button-text:                var(--tao-text-default);
    --tao-button-hover-overlay-color: var(--tao-state-hover);
    --tao-button-press-overlay-color: var(--tao-state-active);
  }

  /* ─── Reduced motion ─────────────────────────────────── */

  /* ─── Clickable cards ───────────────────────────────────── */

  .work-card[data-project] {
    cursor: pointer;
  }

  .work-card[data-project]:focus-visible {
    outline: var(--tao-border-width-md) solid var(--tao-state-focus);
    outline-offset: 3px;
  }

  /* ─── Modal backdrop ─────────────────────────────────────── */

  .cs-modal {
    border: none;
    padding: var(--tao-spacing-md);
    background: transparent;
    max-width: 100%;
    max-height: 100%;
    width: 100%;
    height: 100%;
    inset: 0;
    position: fixed;
    overflow: hidden;
  }

  .cs-modal[open] {
    display: flex;
    align-items: stretch;
    justify-content: center;
  }

  .cs-modal::backdrop {
    background: color-mix(in srgb, var(--tao-surface-brand-1-strongest) 55%, transparent);
    backdrop-filter: blur(4px);
    transition: opacity 400ms ease, backdrop-filter 400ms ease;
  }

  .cs-modal[open]::backdrop {
    opacity: 1;
  }

  @starting-style {
    .cs-modal[open]::backdrop {
      opacity: 0;
    }
  }

  /* ─── Modal inner panel ──────────────────────────────────── */

  .cs-modal__inner {
    position: relative;
    transform-origin: center center;
    width: min(1400px, calc(100vw - var(--tao-spacing-xl) * 2));
    background: var(--tao-surface-neutral-white);
    border: var(--tao-border-width-sm) solid var(--tao-border-subtle);
    border-radius: var(--tao-radius-xl);
    overflow-y: auto;
    transition:
      opacity  400ms cubic-bezier(0.34, 1.56, 0.64, 1),
      transform 400ms cubic-bezier(0.34, 1.56, 0.64, 1);
    scrollbar-width: thin;
    scrollbar-color: color-mix(in srgb, var(--tao-border-subtle) 60%, transparent) transparent;
  }
  .cs-modal__inner::-webkit-scrollbar {
    width: 6px;
  }
  .cs-modal__inner::-webkit-scrollbar-track {
    background: transparent;
  }
  .cs-modal__inner::-webkit-scrollbar-thumb {
    background: color-mix(in srgb, var(--tao-border-subtle) 80%, transparent);
    border-radius: var(--tao-radius-pill);
  }
  .cs-modal__inner::-webkit-scrollbar-thumb:hover {
    background: var(--tao-border-default);
  }

  .cs-modal[open] .cs-modal__inner {
    opacity: 1;
    transform: scale(1);
  }

  @starting-style {
    .cs-modal[open] .cs-modal__inner {
      opacity: 0;
      transform: scale(0.5);
    }
  }

  .cs-modal__inner--closing {
    opacity: 0 !important;
    transform: scale(0.85) !important;
    transition:
      opacity  220ms cubic-bezier(0.4, 0, 1, 1),
      transform 220ms cubic-bezier(0.4, 0, 1, 1) !important;
  }

  /* ─── Close button ───────────────────────────────────────── */

  .cs-modal__close-wrap {
    position: absolute;
    top: calc(var(--tao-spacing-xl) - var(--tao-spacing-md));
    right: calc(var(--tao-spacing-xxl) - var(--tao-spacing-md));
    z-index: 20;
  }

  .cs-modal__close {
    position: relative;
    flex-shrink: 0;
    background: color-mix(in srgb, var(--tao-surface-neutral-white) 82%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  /* ─── Modal header ───────────────────────────────────────── */

  .cs-modal__header {
    display: flex;
    align-items: center;
    gap: var(--tao-spacing-md);
    padding: var(--tao-spacing-xxl) var(--tao-spacing-xxl) 0;
    /* clear the floated close btn */
    clear: right;
    margin-top: calc(-1 * var(--tao-spacing-lg));
  }

  .cs-modal__icon {
    width: 52px;
    height: 52px;
    flex-shrink: 0;
  }

  .cs-modal__label {
    font-size: var(--tao-typography-size-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--tao-text-brand-2);
    text-transform: uppercase;
    margin: 0 0 var(--tao-spacing-xxs);
  }

  .cs-modal__title {
    font-size: var(--tao-typography-size-xxl);
    font-weight: 700;
    color: var(--tao-text-default);
    margin: 0;
    line-height: 1.2;
  }

  /* ─── Tags row ───────────────────────────────────────────── */

  .cs-modal__tags {
    padding: var(--tao-spacing-md) var(--tao-spacing-xxl) 0;
  }

  /* ─── Hero band ──────────────────────────────────────────── */

  .cs-modal__hero {
    position: relative;
    height: 180px;
    margin: var(--tao-spacing-xl) var(--tao-spacing-xxl) 0;
    border-radius: var(--tao-radius-lg);
    overflow: hidden;
    background: linear-gradient(
      135deg,
      var(--tao-surface-brand-2-subtlest) 0%,
      var(--tao-surface-brand-1-subtle)   50%,
      var(--tao-surface-brand-3-subtlest) 100%
    );
  }

  .cs-modal__hero-glow {
    position: absolute;
    border-radius: var(--tao-radius-circular);
    filter: blur(36px);
  }
  .cs-modal__hero-glow--a {
    width: 220px; height: 220px;
    background: var(--tao-surface-brand-2-subtle);
    top: -40px; left: 10%;
    opacity: 0.6;
  }
  .cs-modal__hero-glow--b {
    width: 180px; height: 180px;
    background: var(--tao-surface-brand-3-subtle);
    bottom: -40px; right: 15%;
    opacity: 0.5;
  }

  /* ─── Body ───────────────────────────────────────────────── */

  .cs-modal__body {
    padding: var(--tao-spacing-xxl);
    display: flex;
    flex-direction: column;
    gap: var(--tao-spacing-xl);
  }

  .cs-modal__cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--tao-spacing-xl);
  }

  .cs-modal__section-title {
    font-size: var(--tao-typography-size-sm);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--tao-text-subtle);
    margin: 0 0 var(--tao-spacing-sm);
  }

  .cs-modal__text {
    font-size: var(--tao-typography-size-md);
    color: var(--tao-text-subtle);
    line-height: 1.7;
    margin: 0;
  }

  .cs-modal__outcomes {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--tao-spacing-sm);
  }

  .cs-modal__outcomes li {
    display: flex;
    align-items: flex-start;
    gap: var(--tao-spacing-sm);
    font-size: var(--tao-typography-size-md);
    color: var(--tao-text-subtle);
    line-height: 1.5;
  }

  .cs-modal__outcomes li::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: var(--tao-radius-circular);
    background: var(--tao-surface-brand-2-default);
    margin-top: var(--tao-spacing-xs);
    flex-shrink: 0;
  }

  /* ─── Rich case study ───────────────────────────────────── */

  .cs-rich { display: flex; flex-direction: column; }
  .cs-rich[hidden] { display: none; }

  /* Hero */
  .cs-rich__hero {
    padding: var(--tao-spacing-xxxl) var(--tao-spacing-xxl) var(--tao-spacing-xl);
    background: color-mix(in srgb, var(--tao-surface-brand-2-subtlest) 50%, var(--tao-surface-neutral-white));
    border-bottom: var(--tao-border-width-sm) solid var(--tao-border-subtle);
  }
  .cs-rich__hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--tao-spacing-xxl);
    align-items: center;
  }
  .cs-rich__hero-text {
    display: flex;
    flex-direction: column;
    gap: var(--tao-spacing-lg);
  }
  .cs-rich__badge {
    display: inline-flex;
    align-self: flex-start;
    font-size: var(--tao-typography-size-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--tao-text-ai);
    background: var(--tao-surface-ai-subtlest);
    border: var(--tao-border-width-sm) solid color-mix(in srgb, var(--tao-border-ai) calc(var(--tao-opacity-64) * 100%), transparent);
    border-radius: var(--tao-radius-pill);
    padding: var(--tao-spacing-xs) var(--tao-spacing-md);
  }
  .cs-rich__h1 {
    font-size: var(--tao-typography-size-xxxl);
    font-weight: 800;
    line-height: 1.08;
    color: var(--tao-text-default);
    margin: 0;
    letter-spacing: -0.02em;
  }
  .cs-rich__h1 em {
    font-style: italic;
    color: var(--tao-text-brand-2);
  }
  .cs-rich__lead {
    font-size: var(--tao-typography-size-md);
    color: var(--tao-text-subtle);
    line-height: 1.65;
    margin: 0;
    max-width: 52ch;
  }

  .cs-rich__problem {
    display: flex;
    flex-direction: column;
    gap: var(--tao-spacing-xs);
  }
  .cs-rich__problem-label {
    font-size: var(--tao-typography-size-sm);
    font-weight: 700;
    color: var(--tao-text-default);
  }
  .cs-rich__problem-text {
    font-size: var(--tao-typography-size-lg);
    font-weight: 700;
    color: var(--tao-text-brand-2);
    line-height: 1.4;
    margin: 0;
  }

  /* Task block inside hypothesis */
  .cs-rich__task {
    display: flex;
    flex-direction: column;
    gap: var(--tao-spacing-sm);
    padding: var(--tao-spacing-lg) var(--tao-spacing-xl);
    background: var(--tao-surface-neutral-subtlest);
    border-radius: var(--tao-radius-lg);
  }
  .cs-rich__task-label {
    font-size: var(--tao-typography-size-sm);
    font-weight: 700;
    color: var(--tao-text-brand-1);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* Business outcome rows */
  .cs-rich__outcomes {
    display: flex;
    flex-direction: column;
    gap: var(--tao-spacing-xs);
  }
  .cs-rich__outcome {
    display: flex;
    align-items: flex-start;
    gap: var(--tao-spacing-sm);
    background: var(--tao-surface-news-subtlest);
    border-radius: var(--tao-radius-md);
    padding: var(--tao-spacing-sm) var(--tao-spacing-md);
    font-size: var(--tao-typography-size-sm);
    color: var(--tao-text-default);
  }
  .cs-rich__outcome-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    color: var(--tao-text-news);
  }
  .cs-rich__outcome-text {
    font-weight: 400;
  }
  .cs-rich__stat-row {
    display: flex;
    align-items: center;
    gap: var(--tao-spacing-lg);
    padding: var(--tao-spacing-md) var(--tao-spacing-lg);
    background: var(--tao-surface-neutral-white);
    border: var(--tao-border-width-sm) solid var(--tao-border-subtle);
    border-radius: var(--tao-radius-lg);
    width: fit-content;
  }
  .cs-rich__stat-box { display: flex; flex-direction: column; gap: 2px; }
  .cs-rich__stat-value {
    font-size: var(--tao-typography-size-xxl);
    font-weight: 800;
    color: var(--tao-text-brand-2);
    line-height: 1;
  }
  .cs-rich__stat-label {
    font-size: var(--tao-typography-size-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--tao-text-subtle);
  }
  .cs-rich__stat-sep {
    width: 1px;
    height: 40px;
    background: var(--tao-border-subtle);
    flex-shrink: 0;
  }
  .cs-rich__stat-info { display: flex; flex-direction: column; gap: 2px; }
  .cs-rich__stat-info-title {
    font-size: var(--tao-typography-size-md);
    font-weight: 700;
    color: var(--tao-text-default);
  }
  .cs-rich__stat-info-desc {
    font-size: var(--tao-typography-size-sm);
    color: var(--tao-text-subtle);
  }

  /* Hero visual */
  .cs-rich__hero-visual { position: relative; }
  .cs-rich__hero-img {
    width: 100%;
    height: auto;
    border-radius: var(--tao-radius-lg);
    border: var(--tao-border-width-sm) solid var(--tao-border-subtle);
    display: block;
    box-shadow: 0 8px 32px color-mix(in srgb, var(--tao-border-brand-2) 12%, transparent);
  }
  .cs-rich__wf { width: 100%; display: flex; flex-direction: column; gap: var(--tao-spacing-md); }
  .cs-rich__wf-bar {
    height: 12px;
    width: 40%;
    background: var(--tao-surface-brand-2-subtle);
    border-radius: var(--tao-radius-pill);
  }
  .cs-rich__wf-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--tao-spacing-sm);
  }
  .cs-rich__wf-card {
    background: var(--tao-surface-neutral-white);
    border: var(--tao-border-width-sm) solid var(--tao-border-subtle);
    border-radius: var(--tao-radius-md);
    padding: var(--tao-spacing-sm);
    display: flex;
    flex-direction: column;
    gap: var(--tao-spacing-xs);
  }
  .cs-rich__wf-thumb {
    aspect-ratio: 1;
    background: color-mix(in srgb, var(--tao-surface-brand-2-subtle) 40%, transparent);
    border-radius: var(--tao-radius-sm);
  }
  .cs-rich__wf-line {
    height: 6px;
    background: var(--tao-border-subtle);
    border-radius: var(--tao-radius-pill);
  }
  .cs-rich__wf-line--short { width: 65%; }

  /* Sections */
  .cs-rich__section {
    padding: var(--tao-spacing-xxl);
    display: flex;
    flex-direction: column;
    gap: var(--tao-spacing-xxl);
    border-bottom: var(--tao-border-width-sm) solid var(--tao-border-subtle);
  }
  .cs-rich__section--alt {
    background: color-mix(in srgb, var(--tao-surface-brand-1-subtlest) 40%, var(--tao-surface-neutral-white));
  }
  .cs-rich__section-hd { display: flex; flex-direction: column; gap: var(--tao-spacing-sm); max-width: 60ch; }
  .cs-rich__section-hd--center { max-width: 100%; }
  .cs-rich__h2 {
    font-size: var(--tao-typography-size-xxl);
    font-weight: 800;
    color: var(--tao-text-default);
    margin: 0;
    letter-spacing: -0.02em;
  }
  .cs-rich__body-text {
    font-size: var(--tao-typography-size-md);
    color: var(--tao-text-subtle);
    line-height: 1.65;
    margin: 0;
  }

  /* Steps */
  .cs-rich__steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--tao-spacing-xl);
  }

  .cs-rich__steps--5 {
    grid-template-columns: repeat(5, 1fr);
  }
  .cs-rich__steps--4 {
    grid-template-columns: repeat(4, 1fr);
  }
  .cs-rich__steps--architecture {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .cs-rich__step { display: flex; flex-direction: column; gap: var(--tao-spacing-md); }
  .cs-rich__step-icon {
    width: 52px;
    height: 52px;
    border-radius: var(--tao-radius-lg);
    background: var(--tao-surface-neutral-white);
    border: var(--tao-border-width-sm) solid var(--tao-border-subtle);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--tao-text-brand-2);
    flex-shrink: 0;
  }
  .cs-rich__step-title {
    font-size: var(--tao-typography-size-md);
    font-weight: 700;
    color: var(--tao-text-default);
    margin: 0;
  }
  .cs-rich__step-desc {
    font-size: var(--tao-typography-size-sm);
    color: var(--tao-text-subtle);
    line-height: 1.6;
    margin: 0;
  }

  /* Hypothesis */
  .cs-rich__hyp {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--tao-spacing-xxl);
    align-items: start;
  }
  /* Two-column variant: content left, image right */
  .cs-rich__hyp--split {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--tao-spacing-xxl);
    align-items: start;
  }
  /* Inner content column stacks vertically */
  .cs-rich__hyp--solo {
    display: flex;
    flex-direction: column;
    gap: var(--tao-spacing-xl);
  }
  .cs-rich__hyp-visual { position: relative; }
  .cs-rich__hyp-img {
    width: 100%;
    height: auto;
    border-radius: var(--tao-radius-lg);
    border: var(--tao-border-width-sm) solid var(--tao-border-subtle);
    display: block;
    box-shadow: 0 8px 32px color-mix(in srgb, var(--tao-border-brand-2) 12%, transparent);
  }
  video.cs-rich__hyp-img {
    overflow: hidden;
  }
  /* --flip handled via DOM order in --split layouts */

  /* Hypothesis divider */
  .cs-rich__divider {
    border: none;
    border-top: var(--tao-border-width-sm) solid var(--tao-border-subtle);
    margin: 0 var(--tao-spacing-xxl);
  }

  /* ── Contribution System ─────────────────────────────────── */
  .cs-rich__contribution {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--tao-spacing-xxl);
    align-items: center;
  }
  .cs-rich__contribution-text {
    display: flex;
    flex-direction: column;
    gap: var(--tao-spacing-lg);
  }
  .cs-rich__contribution-diagram {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  /* ── Contribution loop diagram — mirrors hero triangle structure ── */
  .cs-loop-diagram {
    position: relative;
    width: 100%;
    max-width: 560px;
    aspect-ratio: 560 / 340;
    margin: 0 auto;
  }

  .cs-loop-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  /* Marching-ant circles (mirrors hero .tri-line animation) */
  .cs-loop-circle {
    stroke: var(--tao-border-brand-2);
    stroke-width: 1.5;
    stroke-dasharray: 7 5;
    stroke-dashoffset: 0;
    opacity: 0.4;
    fill: none;
  }
  .cs-loop-circle--l { animation: cs-loop-dash 5s linear infinite; }
  .cs-loop-circle--r { animation: cs-loop-dash 5s 2.5s linear infinite; }
  @keyframes cs-loop-dash { to { stroke-dashoffset: -48; } }

  /* Traveller dot — transparent overlay */
  #cs-contrib-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  /* Node chips — same look as hero .node */
  .cs-loop-node {
    position: absolute;
    display: flex;
    align-items: center;
    gap: var(--tao-spacing-xxs);
    font-size: var(--tao-typography-size-sm);
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--tao-text-default);
    background: var(--tao-surface-neutral-white);
    border: var(--tao-border-width-sm) solid var(--tao-border-default);
    border-radius: var(--tao-radius-sm);
    padding: var(--tao-spacing-xxs) var(--tao-spacing-sm);
    box-shadow: 0 2px 8px color-mix(in srgb, var(--tao-border-default) 32%, transparent);
    white-space: nowrap;
    transform: translate(-50%, -50%);
  }
  .cs-loop-node__icon {
    color: var(--tao-text-brand-2);
    flex-shrink: 0;
  }
  /* Positions: circles at (150,170,r=110) and (410,170,r=110) in 560×340 */
  /* Top nodes at y=60  → 17.6%  |  Bottom at y=280 → 82.4%            */
  /* Left  x=150 → 26.8%         |  Right  x=410    → 73.2%            */
  .cs-loop-node--tl { left: 26.8%; top: 17.6%; }
  .cs-loop-node--bl { left: 26.8%; top: 82.4%; }
  .cs-loop-node--tr { left: 73.2%; top: 17.6%; }
  .cs-loop-node--br { left: 73.2%; top: 82.4%; }

  /* Centre intersection card — mirrors hero .center-card */
  .cs-loop-center {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cs-loop-center__ring {
    position: absolute;
    width: 58px;
    height: 58px;
    border-radius: var(--tao-radius-circular);
    border: var(--tao-border-width-sm) solid var(--tao-border-brand-2);
    opacity: 0;
    animation: cs-loop-pulse-ring 3s 1s ease-out infinite;
  }
  .cs-loop-center__ring--2 {
    animation: cs-loop-pulse-ring 3s 2s ease-out infinite;
  }
  @keyframes cs-loop-pulse-ring {
    0%   { transform: scale(1);   opacity: 0.7; }
    100% { transform: scale(2.2); opacity: 0;   }
  }
  .cs-loop-center__body {
    position: relative;
    z-index: 1;
    width: 52px;
    height: 52px;
    background: var(--tao-surface-neutral-white);
    border-radius: var(--tao-radius-lg);
    border: var(--tao-border-width-sm) solid var(--tao-border-default);
    box-shadow: 0 4px 16px color-mix(in srgb, var(--tao-border-default) 48%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ── Design Tokens section ──────────────────────────────── */
  .cs-rich__tokens-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--tao-spacing-xxl);
    align-items: center;
  }
  .cs-rich__tokens-text {
    display: flex;
    flex-direction: column;
    gap: var(--tao-spacing-lg);
  }
  .cs-rich__tokens-text em {
    font-style: italic;
    color: var(--tao-text-brand-1);
  }
  .cs-rich__tokens-visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cs-tokens-img-wrap {
    position: relative;
    width: 100%;
    border-radius: var(--tao-radius-md);
    overflow: hidden;
    border: var(--tao-border-width-sm) solid var(--tao-border-default);
    box-shadow: 0 8px 32px color-mix(in srgb, var(--tao-border-default) 40%, transparent);
    aspect-ratio: 16 / 10;
    background: var(--tao-surface-brand-1-subtlest);
  }
  .cs-tokens-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.45s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }
  .cs-tokens-img--active {
    opacity: 1;
    pointer-events: auto;
  }

  /* Toggle */
  .cs-tokens-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0;
    background: var(--tao-surface-brand-1-subtlest);
    border: var(--tao-border-width-sm) solid var(--tao-border-default);
    border-radius: var(--tao-radius-md);
    padding: var(--tao-spacing-xxs);
    align-self: flex-start;
  }
  .cs-tokens-toggle__btn {
    display: inline-flex;
    align-items: center;
    gap: var(--tao-spacing-xxs);
    font-size: var(--tao-typography-size-sm);
    font-weight: 600;
    color: var(--tao-text-subtle);
    background: transparent;
    border: none;
    border-radius: calc(var(--tao-radius-md) - 3px);
    padding: var(--tao-spacing-xs) var(--tao-spacing-md);
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }
  .cs-tokens-toggle__btn--active {
    background: var(--tao-surface-neutral-white);
    color: var(--tao-text-default);
    box-shadow: 0 1px 4px color-mix(in srgb, var(--tao-border-default) 40%, transparent);
  }
  .cs-tokens-toggle__btn:hover:not(.cs-tokens-toggle__btn--active) {
    background: var(--tao-state-hover);
    color: var(--tao-text-default);
  }
  .cs-tokens-toggle__btn:focus-visible {
    outline: var(--tao-border-width-md) solid var(--tao-border-brand-2);
    outline-offset: 2px;
    border-radius: var(--tao-radius-sm);
  }

  /* ── Pillar 4-col grid (Design Systems modal) ───────────── */
  .cs-rich__pillars-4 {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--tao-spacing-sm) var(--tao-spacing-md);
    align-items: start;
  }
  .cs-rich__pillar-col-label {
    display: flex;
    align-items: center;
    padding-bottom: var(--tao-spacing-xs);
  }
  .cs-rich__pillar-label {
    display: inline-block;
    font-size: var(--tao-typography-size-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--tao-text-brand-1);
    background: var(--tao-surface-brand-1-subtlest);
    border: var(--tao-border-width-sm) solid var(--tao-border-brand-1);
    border-radius: var(--tao-radius-pill);
    padding: var(--tao-spacing-xxs) var(--tao-spacing-md);
  }
  .cs-rich__pillar-label--culture {
    color: var(--tao-text-brand-3);
    background: var(--tao-surface-brand-3-subtlest);
    border-color: var(--tao-border-brand-3);
  }
  .cs-rich__pillar {
    display: flex;
    flex-direction: column;
    gap: var(--tao-spacing-sm);
    background: var(--tao-surface-brand-1-subtlest);
    border: var(--tao-border-width-sm) solid var(--tao-border-subtle);
    border-radius: var(--tao-radius-lg);
    padding: var(--tao-spacing-lg);
    height: 100%;
  }
  .cs-rich__pillar--culture {
    background: var(--tao-surface-brand-3-subtlest);
    border-color: var(--tao-border-brand-3);
  }
  .cs-rich__pillar .cs-rich__step-icon {
    flex-shrink: 0;
  }
  .cs-rich__pillar--culture .cs-rich__step-icon {
    color: var(--tao-text-brand-3);
  }
  .cs-rich__pillar-text {
    display: flex;
    flex-direction: column;
    gap: var(--tao-spacing-xs);
    flex: 1;
  }
  .cs-rich__pillar .cs-rich__step-title {
    font-size: var(--tao-typography-size-lg);
  }
  .cs-rich__pillar-url {
    font-size: var(--tao-typography-size-md);
    font-weight: 600;
    color: var(--tao-text-brand-1);
    letter-spacing: 0.02em;
    margin: 0;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: var(--tao-spacing-xxs);
  }
  .cs-rich__pillar-url--link {
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    text-decoration-color: color-mix(in srgb, var(--tao-text-brand-1) 40%, transparent);
    transition: text-decoration-color 0.15s ease, color 0.15s ease;
  }
  .cs-rich__pillar-url--link:hover {
    text-decoration-color: var(--tao-text-brand-1);
    color: var(--tao-text-brand-2);
  }
  .cs-rich__pillar--culture .cs-rich__pillar-url {
    color: var(--tao-text-brand-3);
  }
  .cs-rich__pillar .cs-rich__step-desc {
    font-size: var(--tao-typography-size-md);
  }
  .cs-rich__pillar-goal {
    font-size: var(--tao-typography-size-md);
    color: var(--tao-text-subtle);
    margin: var(--tao-spacing-xs) 0 0;
    line-height: 1.5;
    border-top: var(--tao-border-width-sm) solid var(--tao-border-subtle);
    padding-top: var(--tao-spacing-sm);
  }
  .cs-rich__pillar-goal strong {
    color: var(--tao-text-default);
    font-weight: 600;
  }
  .cs-rich__hyp-content { display: flex; flex-direction: column; gap: var(--tao-spacing-lg); }
  .cs-rich__hyp-badge {
    font-size: var(--tao-typography-size-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--tao-text-brand-1);
    background: var(--tao-surface-brand-1-subtlest);
    padding: var(--tao-spacing-xxs) var(--tao-spacing-sm);
    border-radius: var(--tao-radius-pill);
    width: fit-content;
  }
  .cs-rich__h3 {
    font-size: var(--tao-typography-size-xl);
    font-weight: 700;
    color: var(--tao-text-default);
    margin: 0;
  }
  .cs-rich__quote {
    font-size: var(--tao-typography-size-xl);
    font-style: normal;
    font-weight: 700;
    color: var(--tao-text-default);
    line-height: 1.4;
    margin: 0;
  }

  /* Diagrams */
  .cs-rich__hyp-diagram {
    background: var(--tao-surface-neutral-white);
    border: var(--tao-border-width-sm) solid var(--tao-border-subtle);
    border-radius: var(--tao-radius-xl);
    padding: var(--tao-spacing-xl);
  }
  .cs-rich__diagram {
    display: flex;
    flex-direction: column;
    gap: var(--tao-spacing-lg);
    align-items: stretch;
  }
  .cs-rich__diagram-row {
    display: flex;
    align-items: center;
    gap: var(--tao-spacing-md);
  }
  .cs-rich__diagram-box {
    border: var(--tao-border-width-md) dashed color-mix(in srgb, var(--tao-border-brand-2) 40%, transparent);
    border-radius: var(--tao-radius-md);
    padding: var(--tao-spacing-md);
    display: flex;
    flex-direction: column;
    gap: var(--tao-spacing-xs);
    flex: 1;
  }
  .cs-rich__diagram-box--narrow { flex: 0 0 45%; }
  .cs-rich__diagram-bar {
    height: 8px;
    width: 50%;
    background: color-mix(in srgb, var(--tao-surface-brand-2-subtle) 80%, transparent);
    border-radius: var(--tao-radius-pill);
  }
  .cs-rich__diagram-fill {
    height: 32px;
    background: color-mix(in srgb, var(--tao-surface-brand-2-subtlest) 80%, transparent);
    border-radius: var(--tao-radius-sm);
  }
  .cs-rich__diagram-fill--tall { height: 52px; }
  .cs-rich__diagram-arrow { color: var(--tao-text-subtlest); font-size: var(--tao-typography-size-lg); flex-shrink: 0; }
  .cs-rich__diagram-label {
    font-size: var(--tao-typography-size-xs);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--tao-text-subtlest);
    text-align: center;
  }

  /* Density grid */
  .cs-rich__density-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--tao-spacing-xs);
  }
  .cs-rich__density-cell {
    aspect-ratio: 1;
    background: color-mix(in srgb, var(--tao-surface-brand-2-subtle) 30%, transparent);
    border-radius: var(--tao-radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--tao-typography-size-md);
    font-weight: 700;
    color: var(--tao-text-brand-2);
  }
  .cs-rich__density-exceeded {
    grid-column: 1 / -1;
    border: var(--tao-border-width-md) dashed color-mix(in srgb, var(--tao-border-danger) 60%, transparent);
    border-radius: var(--tao-radius-sm);
    padding: var(--tao-spacing-sm);
    text-align: center;
    font-size: var(--tao-typography-size-xs);
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--tao-text-danger);
  }

  /* Results two-group row */
  .cs-rich__results-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--tao-spacing-lg);
    align-items: start;
  }
  .cs-rich__results-group {
    display: flex;
    flex-direction: column;
    gap: var(--tao-spacing-sm);
  }
  .cs-rich__results-title {
    font-size: var(--tao-typography-size-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--tao-text-subtle);
  }

  /* Metrics */
  .cs-rich__metrics {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--tao-spacing-md);
  }
  .cs-rich__metrics--3 {
    grid-template-columns: repeat(3, 1fr);
  }
  .cs-rich__metric {
    background: var(--tao-surface-neutral-white);
    border: var(--tao-border-width-sm) solid var(--tao-border-subtle);
    border-radius: var(--tao-radius-lg);
    padding: var(--tao-spacing-md) var(--tao-spacing-lg);
    display: flex;
    flex-direction: column;
    gap: var(--tao-spacing-xs);
  }
  .cs-rich__metric-val {
    font-size: var(--tao-typography-size-xxl);
    font-weight: 800;
    color: var(--tao-text-default);
    line-height: 1;
  }
  .cs-rich__metric--brand .cs-rich__metric-val {
    color: var(--tao-text-brand-1);
  }
  .cs-rich__metric-lbl {
    font-size: var(--tao-typography-size-sm);
    font-weight: 400;
    color: var(--tao-text-subtle);
  }

  /* ─── Reduced motion ─────────────────────────────────────── */

  @media (prefers-reduced-motion: reduce) {
    .works__header, .work-card, .works__carousel { transition: none; opacity: 1; transform: none; }
    .works__carousel-track { transition: none; }
    .works__dot { transition: none; }
    .work-card__orb { animation: none; }
    .cs-modal__inner { transition: none; }
    .cs-modal::backdrop { transition: none; }
    .cs-loop-circle { animation: none; }
    .cs-loop-center__ring { animation: none; }
    .cs-tokens-img { transition: none; }
  }

  /* ─── Responsive · tablet ────────────────────────────── */

  @media (max-width: 960px) {
    .works__grid { grid-template-columns: repeat(2, 1fr); }
    .work-card--wide { grid-column: 1 / -1; }
    .works__carousel-track .work-card {
      width: calc((100% - var(--tao-spacing-md)) / 2);
    }
    .cs-modal__cols { grid-template-columns: 1fr; }

    /* Modal · tablet */
    .cs-modal__inner { padding: var(--tao-spacing-xl); }
    .cs-modal__close-wrap {
      top: calc(var(--tao-spacing-lg) - var(--tao-spacing-md));
      right: calc(var(--tao-spacing-xl) - var(--tao-spacing-md));
    }
    .cs-rich__hero-inner { grid-template-columns: 1fr; }
    .cs-rich__hero-visual { display: none; }
    .cs-rich__hyp--split { grid-template-columns: 1fr; }
    .cs-rich__contribution { grid-template-columns: 1fr; }
    .cs-rich__hyp--flip .cs-rich__hyp-visual { order: -1; }
    .cs-rich__results-row { grid-template-columns: 1fr; }
    .cs-rich__pillars-4 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .cs-rich__pillar-col-label[style] { grid-column: span 1 !important; }
    .cs-rich__steps--5,
    .cs-rich__steps--4,
    .cs-rich__steps--architecture,
    .cs-rich__steps { grid-template-columns: repeat(2, 1fr); }
    .cs-rich__metrics { grid-template-columns: repeat(2, 1fr); }
    .cs-rich__metrics--3 { grid-template-columns: repeat(3, 1fr); }
    .cs-rich__section { padding: var(--tao-spacing-xl); }
    .cs-rich__section-hd { margin-bottom: var(--tao-spacing-lg); }
    .cs-rich__h1 { font-size: var(--tao-typography-size-xxl); }
    .cs-rich__quote { font-size: var(--tao-typography-size-lg); }
    .cs-rich__divider { margin: 0 var(--tao-spacing-lg); }
  }

  /* ─── Responsive · mobile ────────────────────────────── */

  @media (max-width: 600px) {
    .works__grid { grid-template-columns: 1fr; }
    .work-card--wide { grid-column: 1; flex-direction: column; }
    .work-card__dark-visual { width: 100%; height: 160px; }
    .works__carousel-track .work-card { flex: 0 0 85%; width: 85%; }
    .works__dots { display: flex; }
    .works__title { font-size: var(--tao-typography-size-xl); }
    .work-card--dark .work-card__title,
    .work-card--brand .work-card__title { font-size: var(--tao-typography-size-xl); }
    .cs-modal__title { font-size: var(--tao-typography-size-xl); }
    .cs-modal__hero { height: 120px; }
    .cs-modal__header { flex-direction: column; align-items: flex-start; }

    /* Modal · mobile */
    .cs-modal__inner { padding: var(--tao-spacing-lg) var(--tao-spacing-md); }
    .cs-modal__close-wrap {
      top: calc(var(--tao-spacing-md) - var(--tao-spacing-md));
      right: calc(var(--tao-spacing-md) - var(--tao-spacing-md));
    }
    .cs-rich__section { padding: var(--tao-spacing-lg) var(--tao-spacing-md); }
    .cs-rich__hero { padding: var(--tao-spacing-xl) var(--tao-spacing-md) var(--tao-spacing-lg); }
    .cs-rich__h1 { font-size: var(--tao-typography-size-xl); }
    .cs-rich__h2 { font-size: var(--tao-typography-size-xl); }
    .cs-rich__quote { font-size: var(--tao-typography-size-md); }
    .cs-rich__stat-row { flex-direction: column; gap: var(--tao-spacing-md); }
    .cs-rich__pillars-4 { grid-template-columns: 1fr; }
    .cs-rich__pillar-col-label { display: none; }
    .cs-rich__stat-sep { display: none; }
    .cs-rich__steps--5,
    .cs-rich__steps--4,
    .cs-rich__steps--architecture,
    .cs-rich__steps { grid-template-columns: 1fr; }
    .cs-rich__metrics,
    .cs-rich__metrics--3 { grid-template-columns: 1fr 1fr; }
    .cs-rich__hyp { grid-template-columns: 1fr; }
    .cs-rich__results-row { grid-template-columns: 1fr; }
    .cs-rich__problem-text { font-size: var(--tao-typography-size-md); }
    .cs-rich__divider { margin: 0 var(--tao-spacing-md); }
    .cs-rich__badge { font-size: var(--tao-typography-size-xs); }
  }
</style>

<script>
  (function () {
    const section = document.getElementById('work');
    if (!section) return;

    // ── Intersection observer for entrance animation
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            section.classList.add('in-view');
            observer.disconnect();
          }
        });
      },
      { threshold: 0.1 }
    );
    observer.observe(section);

    // ── Carousel
    const track    = document.getElementById('carousel-track');
    const btnPrev  = document.getElementById('carousel-prev');
    const btnNext  = document.getElementById('carousel-next');
    const dotsEl   = document.getElementById('carousel-dots');

    if (track) {
      const cards  = Array.from(track.children);
      const total  = cards.length;
      let current  = 0;

      function visibleCount() {
        return window.innerWidth <= 600 ? 1 : window.innerWidth <= 960 ? 2 : 3;
      }

      function getCardWidth() {
        return cards[0]?.getBoundingClientRect().width ?? 0;
      }

      function getGap() {
        return parseFloat(getComputedStyle(track).gap) || 0;
      }

      function update() {
        const vis = visibleCount();
        const max = total - vis;
        current = Math.max(0, Math.min(current, max));
        const offset = current * (getCardWidth() + getGap());
        track.style.transform = `translateX(-${offset}px)`;
        if (btnPrev) btnPrev.disabled = current === 0;
        if (btnNext) btnNext.disabled = current >= max;

        // Dots
        const dots = dotsEl?.querySelectorAll('.works__dot');
        dots?.forEach((d, i) => d.classList.toggle('works__dot--active', i === current));
      }

      if (btnPrev) {
        btnPrev.addEventListener('click', () => { current--; update(); });
      }
      if (btnNext) {
        btnNext.addEventListener('click', () => { current++; update(); });
      }

      // Arrow key navigation — only when focus is inside this section
      document.addEventListener('keydown', (e) => {
        if (!section?.contains(document.activeElement)) return;
        if (e.key === 'ArrowLeft')  { current--; update(); }
        if (e.key === 'ArrowRight') { current++; update(); }
      });

      // Touch / swipe
      let startX = 0;
      track.addEventListener('touchstart', e => { startX = e.touches[0].clientX; }, { passive: true });
      track.addEventListener('touchend', e => {
        const dx = e.changedTouches[0].clientX - startX;
        if (Math.abs(dx) > 40) { dx < 0 ? current++ : current--; update(); }
      }, { passive: true });

      window.addEventListener('resize', update);

      update();
    }

    // ── Modal ─────────────────────────────────────────────────────

    const PROJECTS = {
      'business-value': {
        label: 'Strategy · 2024',
        title: 'Business Value',
        tags: ['STRATEGY', 'ROI', 'DISCOVERY'],
        overview: 'Working with a mid-size SaaS company, I facilitated a series of discovery workshops to surface misaligned product priorities. By mapping every feature request to a measurable business objective we cut the backlog by 40% and focused engineering effort on the top three revenue drivers.',
        role: 'Lead UX Strategist — responsible for stakeholder interviews, OKR mapping, and presenting findings to the C-suite.',
        outcomes: [
          '40% backlog reduction in 6 weeks',
          'Engineering velocity up 28% after scope clarification',
          '$1.2M in deferred development costs avoided',
          'Unified product vision across 4 cross-functional teams',
        ],
      },
      'technical-precision': {
        label: 'Engineering · 2024',
        title: 'Technical Precision Meets Design',
        tags: ['REACT', 'UI/UX', 'WEBGL'],
        overview: 'A data-heavy SaaS dashboard was suffering from poor perceived performance and inconsistent component behaviour across browsers. I partnered with the front-end team to audit the component library, replace ad-hoc styles with a token system, and introduce WebGL-powered micro-visualisations.',
        role: 'Design Engineer — component audit, token migration, and WebGL prototyping with Three.js.',
        outcomes: [
          'First Contentful Paint reduced by 1.4s',
          'Component library cut from 340 to 190 unique styles',
          'Cross-browser consistency score raised to 98%',
          'Developer onboarding time down from 3 days to 4 hours',
        ],
      },
      'design-systems': {
        label: 'Design Systems · 2023',
        title: 'Design Systems at Scale',
        tags: ['TOKENS', 'FIGMA', 'STYLE DICTIONARY'],
        overview: 'Three product lines were sharing zero design DNA. I architected a multi-tier token system in Style Dictionary, published to npm, and built a Figma variables file that synced automatically via CI. The system now powers web, iOS, and Android from a single source of truth.',
        role: 'Systems Design Lead — token taxonomy, CI pipeline, Figma library governance, and team enablement.',
        outcomes: [
          'One token source serving 3 platforms and 7 product teams',
          'Design-to-dev handoff time cut by 60%',
          'Brand refresh shipped in 2 days vs estimated 6 weeks',
          'Zero visual regressions in first post-launch quarter',
        ],
      },
      'accessibility': {
        label: 'Accessibility · 2024',
        title: 'Accessibility First',
        tags: ['WCAG 2.2', 'A11Y', 'SCREEN READER'],
        overview: 'A government-facing portal was failing WCAG 2.1 AA on 34 criteria. I led an accessibility audit, prioritised remediations by user impact, and embedded a11y checkpoints into the team\'s design and QA processes so regressions could not be merged without passing automated checks.',
        role: 'Accessibility Lead — audit, remediation roadmap, axe-core CI integration, and NVDA/VoiceOver testing.',
        outcomes: [
          'WCAG 2.1 AA compliance achieved across all 80 pages',
          '34 critical violations resolved in 8-week sprint',
          'Keyboard navigation coverage at 100%',
          'Accessibility CI gate blocks 100% of new regressions',
        ],
      },
      'motion-design': {
        label: 'Motion · 2023',
        title: 'Motion & Interaction Design',
        tags: ['GSAP', 'CSS', 'FRAMER'],
        overview: 'A fintech app felt clinical and transactional. I introduced a motion language — easing curves, duration scales, and choreography rules — that gave every state transition a physical weight. The result was a product that users described as "responsive" and "trustworthy" in post-launch research.',
        role: 'Motion Designer — motion language definition, GSAP implementation, and Framer prototyping for user testing.',
        outcomes: [
          'Perceived performance score up 22 points (SUS)',
          'Task abandonment down 18% after motion overhaul',
          'Motion system adopted by 2 sister products within 3 months',
          '"Feels polished" mentions in NPS comments up 3×',
        ],
      },
      'ai-dashboard': {
        label: 'AI / Data · 2025',
        title: 'AI Analytics Dashboard',
        tags: ['AI/ML', 'D3.JS', 'DATA VIZ'],
        overview: 'A machine learning platform was producing accurate predictions that nobody trusted because the outputs were opaque. I redesigned the insights layer — replacing raw probability scores with progressive disclosure charts, confidence bands, and plain-language summaries generated at the edge.',
        role: 'Product Designer + Data Viz Engineer — information architecture, D3.js charts, and prompt-engineered summary UI.',
        outcomes: [
          'Model trust score up from 42% to 79% (user survey)',
          'Time-to-insight reduced from 14 min to 3 min',
          'Dashboard adopted by 6 non-technical teams within a month',
          'Support tickets about "confusing charts" dropped to zero',
        ],
      },
      'mobile-banking': {
        label: 'Fintech · 2023',
        title: 'Mobile Banking Redesign',
        tags: ['MOBILE', 'FINTECH', 'RESEARCH'],
        overview: 'A challenger bank\'s flagship app had a 4.1-star rating dragged down by a cluttered home screen and a multi-step transfer flow that generated 2,000 support tickets a month. Through continuous discovery and iterative testing I simplified the IA and redesigned the money-movement experience.',
        role: 'Senior Product Designer — user research, IA redesign, interaction design, and handoff to a React Native team.',
        outcomes: [
          '38% drop in transfer-related support tickets',
          'App store rating improved from 4.1 to 4.7 in 3 months',
          'Transfer completion rate up from 71% to 94%',
          'Onboarding drop-off reduced by 31%',
        ],
      },
      'ecommerce': {
        label: 'E-Commerce · 2024',
        title: 'E-Commerce Platform',
        tags: ['CONVERSION', 'A/B TEST', 'CRO'],
        overview: 'A fashion retailer\'s checkout converted at 2.1% — well below the industry average of 3.5%. A combination of session recordings, funnel analysis, and qualitative interviews revealed three drop-off clusters: form anxiety, unexpected costs at payment, and mobile tap-target failures.',
        role: 'CRO Designer — heuristic audit, A/B test design in VWO, and final handoff of the winning variant.',
        outcomes: [
          'Checkout conversion lifted from 2.1% to 3.6% (+71%)',
          'Mobile cart abandonment down 29%',
          'Average order value up 11% via smart upsell placement',
          'Annualised revenue impact estimated at €2.4M',
        ],
      },
    };

    // ── Canvas loop diagram ────────────────────────────────────────
    let loopRafId = null;

    function startLoopCanvas() {
      const canvas = document.getElementById('cs-contrib-canvas');
      if (!canvas || loopRafId) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      const ctx = canvas.getContext('2d');
      const W = canvas.width;   // 560
      const H = canvas.height;  // 340

      // Resolve design tokens at runtime
      const rootStyle  = getComputedStyle(document.documentElement);
      const brandBlue  = rootStyle.getPropertyValue('--tao-border-brand-1').trim()         || '#1a2edb';
      const brandLight = rootStyle.getPropertyValue('--tao-surface-brand-1-subtle').trim()  || '#c7d0ff';

      // Lemniscate parameters aligned to SVG circle geometry:
      // left cx=150, right cx=410 → half-distance=130, midpoint cx=280
      const speed   = 0.012;
      const cx      = W / 2;   // 280
      const cy      = H / 2;   // 170
      const hSpread = 130;     // (410-150)/2
      const vAmp    = 95;      // vertical sweep in px

      let t = 0;

      function drawFrame() {
        ctx.clearRect(0, 0, W, H);

        const px = cx + hSpread * Math.sin(t);
        const py = cy + vAmp    * Math.sin(2 * t) / 2;

        // Soft glow halo
        ctx.save();
        ctx.beginPath();
        ctx.arc(px, py, 17, 0, Math.PI * 2);
        ctx.fillStyle   = brandLight;
        ctx.globalAlpha = 0.28;
        ctx.fill();
        ctx.restore();

        // Main dot
        ctx.save();
        ctx.shadowBlur  = 14;
        ctx.shadowColor = brandBlue;
        ctx.fillStyle   = brandBlue;
        const r = 7 + Math.sin(t * 4) * 1.5;
        ctx.beginPath();
        ctx.arc(px, py, r, 0, Math.PI * 2);
        ctx.fill();
        ctx.restore();

        t += speed;
        if (t > Math.PI * 2) t = 0;
        loopRafId = requestAnimationFrame(drawFrame);
      }

      drawFrame();
    }

    function stopLoopCanvas() {
      if (loopRafId) {
        cancelAnimationFrame(loopRafId);
        loopRafId = null;
      }
    }
    // ── /Canvas loop diagram ───────────────────────────────────────

    // ── Tokens light/dark toggle ───────────────────────────────────
    document.querySelectorAll('.cs-tokens-toggle__btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const mode = btn.dataset.mode;
        // Update buttons
        document.querySelectorAll('.cs-tokens-toggle__btn').forEach(b => {
          b.classList.toggle('cs-tokens-toggle__btn--active', b === btn);
          b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
        });
        // Swap images
        document.getElementById('cs-tokens-light').classList.toggle('cs-tokens-img--active', mode === 'light');
        document.getElementById('cs-tokens-dark').classList.toggle('cs-tokens-img--active',  mode === 'dark');
        document.getElementById('cs-tokens-light').setAttribute('aria-hidden', mode === 'dark' ? 'true' : 'false');
        document.getElementById('cs-tokens-dark').setAttribute('aria-hidden', mode === 'light' ? 'true' : 'false');
      });
    });
    // ── /Tokens toggle ─────────────────────────────────────────────

    const modal     = document.getElementById('cs-modal');
    const closeBtn  = document.getElementById('cs-modal-close');
    const inner     = modal?.querySelector('.cs-modal__inner');
    if (!modal || !inner) return;

    function openModal(projectId, sourceCard) {
      // Calculate where the card center is relative to the modal center (viewport center)
      if (sourceCard) {
        const cr = sourceCard.getBoundingClientRect();
        const cardCx = cr.left + cr.width  / 2;
        const cardCy = cr.top  + cr.height / 2;
        const vw = window.innerWidth;
        const vh = window.innerHeight;
        // Express origin as percentage from the inner panel's top-left
        // The inner panel is centered in the viewport
        const innerW = Math.min(1400, vw - 48);
        const innerH = vh - 24;
        const innerLeft = (vw - innerW) / 2;
        const innerTop  = 12;
        const ox = ((cardCx - innerLeft) / innerW * 100).toFixed(1) + '%';
        const oy = ((cardCy - innerTop)  / innerH * 100).toFixed(1) + '%';
        inner.style.transformOrigin = `${ox} ${oy}`;
      } else {
        inner.style.transformOrigin = 'center center';
      }

      // Show the right rich panel
      const richPanels = modal.querySelectorAll('.cs-rich');
      const panelMap = {
        'business-value':      'cs-modal-rich',
        'technical-precision': 'cs-modal-rich-filters',
        'design-systems':      'cs-modal-rich-design-systems',
        'arya':                'cs-modal-rich-arya',
        'agentic-engine':      'cs-modal-rich-agentic',
      };
      richPanels.forEach(p => p.hidden = true);
      const targetId = panelMap[projectId] || 'cs-modal-rich';
      const target = document.getElementById(targetId);
      if (target) target.hidden = false;

      inner.classList.remove('cs-modal__inner--closing');
      document.body.style.overflow = 'hidden';
      modal.showModal();

      // Start canvas animation only for the design-systems panel
      if (projectId === 'design-systems') {
        requestAnimationFrame(startLoopCanvas);
      }
    }

    function closeModal() {
      stopLoopCanvas();
      inner.classList.add('cs-modal__inner--closing');
      inner.addEventListener('transitionend', () => {
        inner.classList.remove('cs-modal__inner--closing');
        document.body.style.overflow = '';
        modal.close();
      }, { once: true });
    }

    // Open on card click / Enter / Space
    document.querySelectorAll('[data-project]').forEach((card) => {
      card.addEventListener('click', () => openModal(card.dataset.project, card));
      card.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          openModal(card.dataset.project, card);
        }
      });
    });

    if (closeBtn) {
      closeBtn.addEventListener('click', closeModal);
    }

    // Click on backdrop closes modal
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    // Escape key
    modal.addEventListener('cancel', (e) => {
      e.preventDefault();
      closeModal();
    });
  })();
</script>
