---
import { CarouselPrev, CarouselNext, ModalClose } from './CarouselNav.jsx';
import { FadersHorizontalIcon, PaletteIcon, StackSimpleIcon, ArrowsClockwiseIcon } from '@phosphor-icons/react';
---

<section class="works" id="work" aria-labelledby="works-heading">
  <div class="works__container">

    <!-- ── Header ──────────────────────────────────────────────── -->
    <div class="works__header">
      <div>
        <h2 class="works__title" id="works-heading">Impactful Case Studies</h2>
        <p class="works__subtitle">Selected work</p>
      </div>
      <nav class="works__nav" aria-label="Browse case studies">
        <CarouselPrev client:load />
        <CarouselNext client:load />
      </nav>
    </div>

    <!-- ── Grid ───────────────────────────────────────────────── -->
    <div class="works__grid">

      <!-- ── Carousel row ──────────────────────────────────────── -->
      <div class="works__carousel" aria-label="Project carousel">
        <div class="works__carousel-wrap">
        <div class="works__carousel-track" id="carousel-track">

          <!-- Card 1 · Arya -->
          <div class="work-card work-card--light work-card--1"
            aria-label="Arya: The Future of Modular UX — case study"
            data-project="arya" role="button" tabindex="0">
            <div class="work-card__icon-wrap" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 256 256" fill="none" aria-hidden="true">
                <!-- wand body -->
                <line x1="48" y1="208" x2="152" y2="104" stroke="currentColor" stroke-width="18" stroke-linecap="round"/>
                <!-- 4-point sparkle star at tip -->
                <path d="M176 80 L188 48 L200 80 L232 92 L200 104 L188 136 L176 104 L144 92 Z" stroke="currentColor" stroke-width="14" stroke-linecap="round" stroke-linejoin="round"/>
                <!-- small sparkle accents -->
                <circle cx="228" cy="44" r="7" fill="currentColor"/>
                <circle cx="136" cy="44" r="5" fill="currentColor"/>
                <circle cx="232" cy="140" r="5" fill="currentColor"/>
              </svg>
            </div>
            <img class="work-card__logo" src="/Docebo.svg" alt="" aria-hidden="true" />
            <div class="work-card__body">
              <h3 class="work-card__title">Arya: The Future of<br />Modular UX</h3>
              <p class="work-card__desc">
                An award-winning project from an internal hackathon that uses generative design and AI templates to let users build custom, no-code interfaces with total flexibility.
              </p>
            </div>
            <span class="work-card__link" aria-hidden="true">Learn more ↗</span>
          </div>

          <!-- Card 2 · Design Systems -->
          <div class="work-card work-card--light work-card--2"
            aria-label="Docebo Design System: Governance at Scale — case study"
            data-project="design-systems" role="button" tabindex="0">
            <div class="work-card__icon-wrap" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 256 256" fill="none" aria-hidden="true">
                <circle cx="128" cy="128" r="40" stroke="currentColor" stroke-width="18"/>
                <line x1="128" y1="32" x2="128" y2="88" stroke="currentColor" stroke-width="18" stroke-linecap="round"/>
                <line x1="128" y1="168" x2="128" y2="224" stroke="currentColor" stroke-width="18" stroke-linecap="round"/>
                <line x1="32" y1="128" x2="88" y2="128" stroke="currentColor" stroke-width="18" stroke-linecap="round"/>
                <line x1="168" y1="128" x2="224" y2="128" stroke="currentColor" stroke-width="18" stroke-linecap="round"/>
              </svg>
            </div>
            <img class="work-card__logo" src="/Docebo.svg" alt="" aria-hidden="true" />
            <div class="work-card__body">
              <h3 class="work-card__title">Docebo Design System:<br />Governance at Scale</h3>
              <p class="work-card__desc">
                Leading a cross-functional initiative to harmonize 50+ modules into a single source of truth, improving consistency for 1,500+ B2B clients.
              </p>
            </div>
            <span class="work-card__link" aria-hidden="true">Learn more ↗</span>
          </div>

          <!-- Card 3 · Cards Information Density -->
          <div class="work-card work-card--light work-card--extra"
            aria-label="Cards Information Density — case study"
            data-project="business-value" role="button" tabindex="0">
            <div class="work-card__icon-wrap" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 256 256" fill="none" aria-hidden="true">
                <rect x="24" y="24" width="96" height="96" rx="10" stroke="currentColor" stroke-width="18"/>
                <rect x="136" y="24" width="96" height="96" rx="10" stroke="currentColor" stroke-width="18"/>
                <rect x="24" y="136" width="96" height="96" rx="10" stroke="currentColor" stroke-width="18"/>
                <rect x="136" y="136" width="96" height="96" rx="10" stroke="currentColor" stroke-width="18"/>
                <line x1="44" y1="176" x2="100" y2="176" stroke="currentColor" stroke-width="14" stroke-linecap="round"/>
                <line x1="44" y1="196" x2="80" y2="196" stroke="currentColor" stroke-width="14" stroke-linecap="round"/>
              </svg>
            </div>
            <img class="work-card__logo" src="/Docebo.svg" alt="" aria-hidden="true" />
            <div class="work-card__body">
              <h3 class="work-card__title">Cards Information<br />Density</h3>
              <p class="work-card__desc">
                Optimizing complex data visualization for high-stakes enterprise
                decision making through rigorous architectural testing.
              </p>
            </div>
            <span class="work-card__link" aria-hidden="true">Learn more ↗</span>
          </div>

          <!-- Card 4 · Filters Complexity -->
          <div class="work-card work-card--light work-card--extra"
            aria-label="Filters Complexity — case study"
            data-project="technical-precision" role="button" tabindex="0">
            <div class="work-card__icon-wrap" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 256 256" fill="none" aria-hidden="true">
                <line x1="40" y1="72" x2="216" y2="72" stroke="currentColor" stroke-width="18" stroke-linecap="round"/>
                <line x1="72" y1="128" x2="184" y2="128" stroke="currentColor" stroke-width="18" stroke-linecap="round"/>
                <line x1="104" y1="184" x2="152" y2="184" stroke="currentColor" stroke-width="18" stroke-linecap="round"/>
              </svg>
            </div>
            <img class="work-card__logo" src="/Docebo.svg" alt="" aria-hidden="true" />
            <div class="work-card__body">
              <h3 class="work-card__title">Filters<br />Complexity</h3>
              <p class="work-card__desc">
                Too many visible filters cluttered the interface, making it
                harder for experienced users to quickly refine data.
              </p>
            </div>
            <span class="work-card__link" aria-hidden="true">Learn more ↗</span>
          </div>


        </div>
        </div><!-- /works__carousel-wrap -->

        <!-- Dots — mobile only -->
        <div class="works__dots" id="carousel-dots" aria-hidden="true">
          <span class="works__dot works__dot--active"></span>
          <span class="works__dot"></span>
          <span class="works__dot"></span>
          <span class="works__dot"></span>
        </div>
      </div>

      <!-- ── Fixed bottom row ───────────────────────────────────── -->

      <!-- Experience Matters (wide) -->
      <div class="work-card work-card--dark work-card--wide work-card--bottom-1"
        aria-label="The Agentic Design Engine — explore blueprint">
        <div class="work-card__dark-content">
          <div>
            <h3 class="work-card__title">The Agentic Design Engine</h3>
            <p class="work-card__desc">
              A model-agnostic layer that replaces manual handoff with deterministic AI assembly. By unifying Figma, Design Tokens, and Production Code, it enables AI agents to build ship-ready layouts instantly.
            </p>
          </div>
          <button class="tao-button tao-button--primary tao-button--md work-card__cta" aria-label="Explore Autonomous System Assembly"
            data-project="agentic-engine" tabindex="0">
            Explore
            <svg width="14" height="14" viewBox="0 0 256 256" fill="none" aria-hidden="true">
              <line x1="40" y1="128" x2="216" y2="128" stroke="currentColor" stroke-width="22" stroke-linecap="round"/>
              <polyline points="144 56 216 128 144 200" stroke="currentColor" stroke-width="22" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
        <div class="work-card__dark-visual" aria-hidden="true">
          <div class="work-card__orb"></div>
        </div>
      </div>

      <!-- Ready to Scale? -->
      <div class="work-card work-card--brand work-card--bottom-2"
        aria-label="Ready to Scale — get started">
        <div class="work-card__brand-icon" aria-hidden="true">
          <svg width="48" height="48" viewBox="0 0 256 256" fill="none" aria-hidden="true">
            <path d="M128 24 C128 24 48 72 48 152 L104 208 L128 232 L152 208 L208 152 C208 72 128 24 128 24 Z"
              stroke="currentColor" stroke-width="16" stroke-linejoin="round"/>
            <circle cx="128" cy="128" r="20"
              stroke="currentColor" stroke-width="16"/>
            <path d="M48 152 L24 192 L72 180"
              stroke="currentColor" stroke-width="16"
              stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M208 152 L232 192 L184 180"
              stroke="currentColor" stroke-width="16"
              stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="work-card__body">
          <h3 class="work-card__title">Ready to Scale?</h3>
          <p class="work-card__desc">Start your next architectural journey with us.</p>
        </div>
        <button class="work-card__circle-btn" aria-label="Get started">
          <svg width="18" height="18" viewBox="0 0 256 256" fill="none" aria-hidden="true">
            <line x1="40" y1="128" x2="216" y2="128"
              stroke="currentColor" stroke-width="20" stroke-linecap="round"/>
            <polyline points="144 56 216 128 144 200"
              stroke="currentColor" stroke-width="20"
              stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>

    </div>
  </div>
</section>

<!-- ── Case Study Modal ────────────────────────────────────────── -->
<dialog class="cs-modal" id="cs-modal" aria-modal="true" aria-labelledby="cs-modal-title">
  <div class="cs-modal__inner">
    <div class="cs-modal__close-wrap">
      <ModalClose client:load />
    </div>

    <!-- ── Rich case study: Cards Information Density ──────── -->
    <div class="cs-rich" id="cs-modal-rich">

      <!-- Hero -->
      <div class="cs-rich__hero">
        <div class="cs-rich__hero-inner">
          <div class="cs-rich__hero-text">
            <div class="cs-rich__badge">Design Management · Case Study</div>
            <h1 class="cs-rich__h1">Cards Information <em>Density.</em></h1>
            <div class="cs-rich__problem">
              <span class="cs-rich__problem-label">Problem</span>
              <p class="cs-rich__problem-text">Legacy requirements and continuous client requests led to overloaded cards that hindered scannability. This information density caused a 15% drop in content discovery and increased task abandonment across the platform.</p>
            </div>
            <div class="cs-rich__stat-row">
              <div class="cs-rich__stat-box">
                <span class="cs-rich__stat-value">15%</span>
                <span class="cs-rich__stat-label">Task Abandonment</span>
              </div>
              <div class="cs-rich__stat-sep"></div>
              <div class="cs-rich__stat-info">
                <span class="cs-rich__stat-info-title">Design Impact</span>
                <span class="cs-rich__stat-info-desc">Validated through a 6-month cross-platform rollout.</span>
              </div>
            </div>
          </div>
          <div class="cs-rich__hero-visual">
            <img class="cs-rich__hero-img" src="/extended.card.png" alt="Cards Information Density — UI screenshot" />
          </div>
        </div>
      </div>

      <!-- Strategic Evolution -->
      <div class="cs-rich__section cs-rich__section--alt">
        <div class="cs-rich__section-hd">
          <h2 class="cs-rich__h2">Strategic Evolution</h2>
          <p class="cs-rich__body-text">A structured methodology designed to align stakeholders and engineering teams on a unified information architecture that scales across diverse product needs.</p>
        </div>
        <div class="cs-rich__steps cs-rich__steps--4">
          <div class="cs-rich__step">
            <div class="cs-rich__step-icon">
              <svg width="22" height="22" viewBox="0 0 256 256" fill="none" aria-hidden="true"><polyline points="232 56 136 152 96 112 24 184" stroke="currentColor" stroke-width="20" stroke-linecap="round" stroke-linejoin="round"/><polyline points="232 56 232 120" stroke="currentColor" stroke-width="20" stroke-linecap="round" stroke-linejoin="round"/><polyline points="168 56 232 56" stroke="currentColor" stroke-width="20" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3 class="cs-rich__step-title">Defining business outcome/goal</h3>
            <p class="cs-rich__step-desc">Improved content ROI by increasing the average number of courses imported per user.</p>
          </div>
          <div class="cs-rich__step">
            <div class="cs-rich__step-icon">
              <svg width="22" height="22" viewBox="0 0 256 256" fill="none" aria-hidden="true"><rect x="32" y="56" width="192" height="160" rx="12" stroke="currentColor" stroke-width="20"/><line x1="80" y1="56" x2="80" y2="24" stroke="currentColor" stroke-width="18" stroke-linecap="round"/><line x1="176" y1="56" x2="176" y2="24" stroke="currentColor" stroke-width="18" stroke-linecap="round"/><line x1="72" y1="128" x2="184" y2="128" stroke="currentColor" stroke-width="16" stroke-linecap="round"/><line x1="72" y1="160" x2="144" y2="160" stroke="currentColor" stroke-width="16" stroke-linecap="round"/></svg>
            </div>
            <h3 class="cs-rich__step-title">JBTD</h3>
            <p class="cs-rich__step-desc">Understanding and comparing information in the library/results page.</p>
          </div>
          <div class="cs-rich__step">
            <div class="cs-rich__step-icon">
              <svg width="22" height="22" viewBox="0 0 256 256" fill="none" aria-hidden="true"><circle cx="128" cy="80" r="48" stroke="currentColor" stroke-width="18"/><path d="M128 144 L128 224" stroke="currentColor" stroke-width="18" stroke-linecap="round"/><path d="M80 184 L176 184" stroke="currentColor" stroke-width="18" stroke-linecap="round"/></svg>
            </div>
            <h3 class="cs-rich__step-title">Need</h3>
            <p class="cs-rich__step-desc">Minimize cognitive effort when consuming information.</p>
          </div>
          <div class="cs-rich__step">
            <div class="cs-rich__step-icon">
              <svg width="22" height="22" viewBox="0 0 256 256" fill="none" aria-hidden="true"><rect x="32" y="32" width="72" height="72" rx="8" stroke="currentColor" stroke-width="18"/><rect x="152" y="32" width="72" height="72" rx="8" stroke="currentColor" stroke-width="18"/><rect x="32" y="152" width="72" height="72" rx="8" stroke="currentColor" stroke-width="18"/><rect x="152" y="152" width="72" height="72" rx="8" stroke="currentColor" stroke-width="18"/><line x1="120" y1="68" x2="152" y2="68" stroke="currentColor" stroke-width="14" stroke-linecap="round"/><line x1="120" y1="188" x2="152" y2="188" stroke="currentColor" stroke-width="14" stroke-linecap="round"/></svg>
            </div>
            <h3 class="cs-rich__step-title">Prioritization</h3>
            <p class="cs-rich__step-desc">We performed a card sorting session with a group of users to prioritize the most important info.</p>
          </div>
          <div class="cs-rich__step">
            <div class="cs-rich__step-icon">
              <svg width="22" height="22" viewBox="0 0 256 256" fill="none" aria-hidden="true"><circle cx="68" cy="128" r="28" stroke="currentColor" stroke-width="18"/><circle cx="188" cy="128" r="28" stroke="currentColor" stroke-width="18"/><line x1="96" y1="128" x2="160" y2="128" stroke="currentColor" stroke-width="16" stroke-linecap="round"/><line x1="68" y1="32" x2="68" y2="100" stroke="currentColor" stroke-width="16" stroke-linecap="round"/><line x1="68" y1="156" x2="68" y2="224" stroke="currentColor" stroke-width="16" stroke-linecap="round"/><line x1="188" y1="32" x2="188" y2="100" stroke="currentColor" stroke-width="16" stroke-linecap="round"/><line x1="188" y1="156" x2="188" y2="224" stroke="currentColor" stroke-width="16" stroke-linecap="round"/></svg>
            </div>
            <h3 class="cs-rich__step-title">Number of elements</h3>
            <p class="cs-rich__step-desc">We made a survey to understand which was the perfect number of information on the card.</p>
          </div>
        </div>
      </div>

      <!-- Strategic Hypotheses -->
      <div class="cs-rich__section">
        <div class="cs-rich__section-hd cs-rich__section-hd--center">
          <h2 class="cs-rich__h2">Strategic Hypotheses</h2>
          <p class="cs-rich__body-text">The core pillars of our architectural exploration.</p>
        </div>

        <!-- H1 -->
        <div class="cs-rich__hyp cs-rich__hyp--split">
          <div class="cs-rich__hyp-content cs-rich__hyp--solo">
            <div class="cs-rich__hyp-badge">Hypothesis 1</div>
            <blockquote class="cs-rich__quote">"If the amount of information on a card does not exceed the threshold identified in the survey, then the card will remain non-enlargeable and display a maximum of 8 items, ensuring clarity and ease of scanning."</blockquote>
            <div class="cs-rich__task">
              <span class="cs-rich__task-label">Task</span>
              <p class="cs-rich__body-text">Review a card that contains a limited amount of information (up to 8 items) and identify the key details you need to understand its content.</p>
            </div>
            <div class="cs-rich__results-row">
              <div class="cs-rich__results-group">
                <span class="cs-rich__results-title">Product &amp; Usability Metrics</span>
                <div class="cs-rich__metrics cs-rich__metrics--3">
                  <div class="cs-rich__metric cs-rich__metric--brand">
                    <span class="cs-rich__metric-val">98%</span>
                    <span class="cs-rich__metric-lbl">Task success</span>
                  </div>
                  <div class="cs-rich__metric cs-rich__metric--brand">
                    <span class="cs-rich__metric-val">2s</span>
                    <span class="cs-rich__metric-lbl">Time on task</span>
                  </div>
                  <div class="cs-rich__metric cs-rich__metric--brand">
                    <span class="cs-rich__metric-val">93%</span>
                    <span class="cs-rich__metric-lbl">CSAT</span>
                  </div>
                </div>
              </div>
              <div class="cs-rich__results-group">
                <span class="cs-rich__results-title">Growth &amp; Business Outcomes</span>
                <div class="cs-rich__outcomes">
                  <div class="cs-rich__outcome">
                    <span class="cs-rich__outcome-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 256 256" fill="none">
                <polyline points="232 56 136 152 96 112 24 184" stroke="currentColor" stroke-width="20" stroke-linecap="round" stroke-linejoin="round"/>
                <polyline points="232 56 232 120" stroke="currentColor" stroke-width="20" stroke-linecap="round"/>
                <polyline points="168 56 232 56" stroke="currentColor" stroke-width="20" stroke-linecap="round"/>
              </svg>
            </span>
                    <span class="cs-rich__outcome-text">+7% improvement in feature retention (30-day)</span>
                  </div>
                  <div class="cs-rich__outcome">
                    <span class="cs-rich__outcome-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 256 256" fill="none">
                <polyline points="232 56 136 152 96 112 24 184" stroke="currentColor" stroke-width="20" stroke-linecap="round" stroke-linejoin="round"/>
                <polyline points="232 56 232 120" stroke="currentColor" stroke-width="20" stroke-linecap="round"/>
                <polyline points="168 56 232 56" stroke="currentColor" stroke-width="20" stroke-linecap="round"/>
              </svg>
            </span>
                    <span class="cs-rich__outcome-text">+4% increase in marketplace course imports (Q1 2025)</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="cs-rich__hyp-visual">
            <img class="cs-rich__hyp-img" src="/cards.info.png" alt="Cards information density — UI reference" />
          </div>
        </div>

        <hr class="cs-rich__divider" />

        <!-- H2 -->
        <div class="cs-rich__hyp cs-rich__hyp--split cs-rich__hyp--flip">
          <div class="cs-rich__hyp-visual">
            <img class="cs-rich__hyp-img" src="/extended.card.png" alt="Enlarged card with high information density" />
          </div>
          <div class="cs-rich__hyp-content cs-rich__hyp--solo">
            <div class="cs-rich__hyp-badge">Hypothesis 2</div>
            <blockquote class="cs-rich__quote">"If we enlarge cards when they contain a high amount of information, then users will be able to scan and access relevant content more easily, because larger cards allow prioritization based on user interest."</blockquote>
            <div class="cs-rich__task">
              <span class="cs-rich__task-label">Task</span>
              <p class="cs-rich__body-text">Imagine you are browsing a page with multiple content cards. Some cards contain more information than others. Your goal is to find the information that is most relevant to you on a card with lots of content.</p>
            </div>
            <div class="cs-rich__results-row">
              <div class="cs-rich__results-group">
                <span class="cs-rich__results-title">Product &amp; Usability Metrics</span>
                <div class="cs-rich__metrics cs-rich__metrics--3">
                  <div class="cs-rich__metric cs-rich__metric--brand">
                    <span class="cs-rich__metric-val">85%</span>
                    <span class="cs-rich__metric-lbl">Task success</span>
                  </div>
                  <div class="cs-rich__metric cs-rich__metric--brand">
                    <span class="cs-rich__metric-val">3s</span>
                    <span class="cs-rich__metric-lbl">Time on task</span>
                  </div>
                  <div class="cs-rich__metric cs-rich__metric--brand">
                    <span class="cs-rich__metric-val">90%</span>
                    <span class="cs-rich__metric-lbl">CSAT</span>
                  </div>
                </div>
              </div>
              <div class="cs-rich__results-group">
                <span class="cs-rich__results-title">Growth &amp; Business Outcomes</span>
                <div class="cs-rich__outcomes">
                  <div class="cs-rich__outcome">
                    <span class="cs-rich__outcome-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 256 256" fill="none">
                <polyline points="232 56 136 152 96 112 24 184" stroke="currentColor" stroke-width="20" stroke-linecap="round" stroke-linejoin="round"/>
                <polyline points="232 56 232 120" stroke="currentColor" stroke-width="20" stroke-linecap="round"/>
                <polyline points="168 56 232 56" stroke="currentColor" stroke-width="20" stroke-linecap="round"/>
              </svg>
            </span>
                    <span class="cs-rich__outcome-text">+10% increase in engagement with high-density content (Q1 2025)</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div><!-- /cs-rich #business-value -->

    <!-- ── Rich case study: Filters Complexity ──────────────── -->
    <div class="cs-rich" id="cs-modal-rich-filters" hidden>

      <!-- Hero -->
      <div class="cs-rich__hero">
        <div class="cs-rich__hero-inner">
          <div class="cs-rich__hero-text">
            <div class="cs-rich__badge">UX Research · Case Study</div>
            <h1 class="cs-rich__h1">Filters <em>Complexity.</em></h1>
            <div class="cs-rich__problem">
              <span class="cs-rich__problem-label">Problem</span>
              <p class="cs-rich__problem-text">Too many visible filters cluttered the interface, making it harder for experienced users to quickly refine data.</p>
            </div>
            <div class="cs-rich__stat-row">
              <div class="cs-rich__stat-box">
                <span class="cs-rich__stat-value">23%</span>
                <span class="cs-rich__stat-label">Drop in Filter Usage</span>
              </div>
              <div class="cs-rich__stat-sep"></div>
              <div class="cs-rich__stat-info">
                <span class="cs-rich__stat-info-title">Design Impact</span>
                <span class="cs-rich__stat-info-desc">Measured across power user cohort over 90-day period.</span>
              </div>
            </div>
          </div>
          <div class="cs-rich__hero-visual">
            <img class="cs-rich__hero-img" src="/Filters.jpg" alt="Filters complexity — UI screenshot" />
          </div>
        </div>
      </div>

      <!-- Strategic Evolution -->
      <div class="cs-rich__section cs-rich__section--alt">
        <div class="cs-rich__section-hd">
          <h2 class="cs-rich__h2">Strategic Evolution</h2>
